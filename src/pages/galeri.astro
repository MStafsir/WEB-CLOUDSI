---
/**
 * galeri.astro
 * Halaman Galeri — CSS masonry grid, lightbox, filter tabs per event
 * Dependencies: BaseLayout, Header, Footer, PageTransition, supabase.ts
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PageTransition from '../components/layout/PageTransition.astro';
import { getEvents, getGallery } from '../lib/supabase';

const events = await getEvents();

// Fetch gallery images untuk semua events
interface GalleryItem {
  id: string;
  event_id: string;
  event_title: string;
  image_url: string;
}

let allImages: GalleryItem[] = [];
for (const event of events) {
  const images = await getGallery(event.id);
  const mapped: GalleryItem[] = images.map(img => ({
    id: img.id,
    event_id: img.event_id,
    event_title: event.title,
    image_url: img.image_url,
  }));
  allImages = [...allImages, ...mapped];
}
---

<BaseLayout title="Galeri" description="Galeri Cloudsi Connect — Momen-momen berharga dari setiap kegiatan angkatan Sistem Informasi.">
  <Header />
  <PageTransition>
    <main id="main-content">

      <!-- Hero mini -->
      <section class="galeri-hero">
        <div class="container-main galeri-hero-inner">
          <h1 class="galeri-title">Galeri</h1>
          <p class="galeri-sub">Momen yang terekam, kenangan yang abadi.</p>
        </div>
      </section>

      <!-- Filter Tabs -->
      <section class="galeri-filters section-pad" style="padding-bottom: 0;">
        <div class="container-main">
          <div class="filter-tabs" id="filter-tabs" role="tablist" aria-label="Filter galeri berdasarkan event">
            <button
              class="filter-tab active"
              data-filter="all"
              role="tab"
              aria-selected="true"
            >
              Semua
            </button>
            {events.map(event => (
              <button
                class="filter-tab"
                data-filter={event.id}
                role="tab"
                aria-selected="false"
              >
                {event.title}
              </button>
            ))}
          </div>
        </div>
      </section>

      <!-- Masonry Grid -->
      <section class="galeri-grid-section section-pad">
        <div class="container-main">
          {allImages.length > 0 ? (
            <div class="masonry-grid" id="masonry-grid">
              {allImages.map((item, index) => (
                <div
                  class="masonry-item"
                  data-event-id={item.event_id}
                  data-lightbox-index={index}
                >
                  <img
                    src={item.image_url}
                    alt={`Galeri ${item.event_title}`}
                    loading={index < 4 ? 'eager' : 'lazy'}
                    decoding="async"
                    width="600"
                    height="400"
                    class="masonry-img"
                  />
                  <div class="masonry-overlay">
                    <span class="overlay-text">{item.event_title}</span>
                  </div>
                </div>
              ))}
            </div>
          ) : (
            <div class="empty-state glass">
              <p class="empty-text">Galeri akan segera diisi dengan momen-momen berharga angkatan.</p>
            </div>
          )}
        </div>
      </section>

      <!-- Lightbox -->
      <div
        class="lightbox"
        id="lightbox"
        role="dialog"
        aria-modal="true"
        aria-label="Lihat foto"
        hidden
      >
        <div class="lightbox-backdrop" id="lightbox-backdrop"></div>
        <button class="lightbox-close" id="lightbox-close" aria-label="Tutup lightbox">&times;</button>
        <button class="lightbox-nav lightbox-prev" id="lightbox-prev" aria-label="Foto sebelumnya">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18L9 12L15 6"/></svg>
        </button>
        <button class="lightbox-nav lightbox-next" id="lightbox-next" aria-label="Foto selanjutnya">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18L15 12L9 6"/></svg>
        </button>
        <div class="lightbox-content">
          <img class="lightbox-img" id="lightbox-img" src="" alt="" />
          <p class="lightbox-caption" id="lightbox-caption"></p>
        </div>
      </div>

    </main>
  </PageTransition>
  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .galeri-hero {
    position: relative;
    height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    text-align: center;
  }

  .galeri-hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .galeri-title {
    font-family: var(--font-display);
    font-size: var(--font-size-h1);
    font-weight: 300;
    letter-spacing: 0.1em;
    color: white;
    margin: 0;
  }

  .galeri-sub {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: hsla(0, 0%, 100%, 0.6);
    margin-top: 0.75rem;
    font-style: italic;
  }

  /* Filter Tabs */
  .filter-tabs {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    padding-bottom: 0.5rem;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .filter-tabs::-webkit-scrollbar {
    display: none;
  }

  .filter-tab {
    flex-shrink: 0;
    padding: 0.5rem 1.25rem;
    border-radius: 9999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    color: hsla(0, 0%, 100%, 0.7);
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all var(--duration-fast) var(--ease-glass);
    white-space: nowrap;
  }

  .filter-tab:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    color: white;
  }

  .filter-tab.active {
    background: var(--color-water-surface);
    border-color: var(--color-water-surface);
    color: white;
  }

  /* Masonry Grid — CSS columns */
  .masonry-grid {
    column-count: 4;
    column-gap: 12px;
  }

  @media (max-width: 1200px) {
    .masonry-grid { column-count: 3; }
  }

  @media (max-width: 768px) {
    .masonry-grid { column-count: 2; }
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 12px;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: opacity var(--duration-normal) var(--ease-glass),
                transform var(--duration-normal) var(--ease-glass);
  }

  .masonry-item.hidden {
    display: none;
  }

  .masonry-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--duration-normal) var(--ease-water);
  }

  .masonry-item:hover .masonry-img {
    transform: scale(1.03);
  }

  /* Overlay */
  .masonry-overlay {
    position: absolute;
    inset: 0;
    background: hsla(210, 60%, 6%, 0.6);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity var(--duration-fast) var(--ease-glass);
  }

  .masonry-item:hover .masonry-overlay {
    opacity: 1;
  }

  .overlay-text {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: white;
    font-weight: 500;
  }

  /* Empty State */
  .empty-state {
    padding: 4rem 2rem;
    text-align: center;
  }

  .empty-text {
    font-family: var(--font-body);
    color: hsla(0, 0%, 100%, 0.5);
    font-style: italic;
    margin: 0;
  }

  /* ========== LIGHTBOX ========== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: hsla(210, 60%, 6%, 0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .lightbox-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 90vw;
    max-height: 85vh;
  }

  .lightbox-img {
    max-width: 90vw;
    max-height: 80vh;
    object-fit: contain;
    border-radius: 8px;
    transform: scale(0.8);
    opacity: 0;
    transition: transform 300ms var(--ease-water),
                opacity 300ms var(--ease-water);
  }

  .lightbox.open .lightbox-img {
    transform: scale(1);
    opacity: 1;
  }

  .lightbox-caption {
    margin-top: 1rem;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0, 0%, 100%, 0.6);
    text-align: center;
  }

  .lightbox-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    z-index: 2;
    background: none;
    border: none;
    color: white;
    font-size: 2rem;
    cursor: pointer;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity var(--duration-fast);
    opacity: 0.7;
  }

  .lightbox-close:hover { opacity: 1; }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    background: var(--glass-bg);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    border: 1px solid var(--glass-border);
    border-radius: 50%;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: white;
    transition: all var(--duration-fast) var(--ease-glass);
    opacity: 0.7;
  }

  .lightbox-nav:hover {
    opacity: 1;
    background: var(--glass-bg-hover);
  }

  .lightbox-prev { left: 1.5rem; }
  .lightbox-next { right: 1.5rem; }

  @media (max-width: 768px) {
    .lightbox-prev { left: 0.5rem; }
    .lightbox-next { right: 0.5rem; }
    .lightbox-nav {
      width: 40px;
      height: 40px;
    }
  }
</style>

<script is:inline>
  function initGaleri() {
    // ========== FILTER TABS ==========
    const tabs = document.querySelectorAll('.filter-tab');
    const items = document.querySelectorAll('.masonry-item');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        const filter = tab.getAttribute('data-filter');

        // Update active tab
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');

        // Show/hide items
        items.forEach(item => {
          const eventId = item.getAttribute('data-event-id');
          if (filter === 'all' || eventId === filter) {
            item.classList.remove('hidden');
          } else {
            item.classList.add('hidden');
          }
        });
      });
    });

    // ========== LIGHTBOX ==========
    const lightbox = document.getElementById('lightbox');
    const lightboxImg = document.getElementById('lightbox-img');
    const lightboxCaption = document.getElementById('lightbox-caption');
    const closeBtn = document.getElementById('lightbox-close');
    const prevBtn = document.getElementById('lightbox-prev');
    const nextBtn = document.getElementById('lightbox-next');
    const backdrop = document.getElementById('lightbox-backdrop');

    if (!lightbox || !lightboxImg) return;

    let currentIndex = -1;
    let previouslyFocused = null;
    const focusableEls = [closeBtn, prevBtn, nextBtn].filter(Boolean);

    function getVisibleItems() {
      return Array.from(document.querySelectorAll('.masonry-item:not(.hidden)'));
    }

    function openLightbox(index) {
      const visible = getVisibleItems();
      if (index < 0 || index >= visible.length) return;

      currentIndex = index;
      previouslyFocused = document.activeElement;

      const item = visible[index];
      const img = item.querySelector('.masonry-img');
      const caption = item.querySelector('.overlay-text');

      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      lightboxCaption.textContent = caption ? caption.textContent : '';

      lightbox.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';

      // Animasi buka
      requestAnimationFrame(() => {
        lightbox.classList.add('open');
      });

      // Focus trap — focus close button
      if (closeBtn) closeBtn.focus();
    }

    function closeLightbox() {
      lightbox.classList.remove('open');
      setTimeout(() => {
        lightbox.setAttribute('hidden', '');
        document.body.style.overflow = '';
        // Return focus
        if (previouslyFocused && previouslyFocused.focus) {
          previouslyFocused.focus();
        }
      }, 300);
    }

    function navigate(direction) {
      const visible = getVisibleItems();
      let newIndex = currentIndex + direction;
      if (newIndex < 0) newIndex = visible.length - 1;
      if (newIndex >= visible.length) newIndex = 0;

      // Quick transition
      lightboxImg.style.opacity = '0';
      lightboxImg.style.transform = 'scale(0.95)';
      setTimeout(() => {
        const item = visible[newIndex];
        const img = item.querySelector('.masonry-img');
        const caption = item.querySelector('.overlay-text');
        lightboxImg.src = img.src;
        lightboxImg.alt = img.alt;
        lightboxCaption.textContent = caption ? caption.textContent : '';
        currentIndex = newIndex;

        requestAnimationFrame(() => {
          lightboxImg.style.opacity = '1';
          lightboxImg.style.transform = 'scale(1)';
        });
      }, 150);
    }

    // Click handlers
    items.forEach((item, _) => {
      item.addEventListener('click', () => {
        const visible = getVisibleItems();
        const visibleIndex = visible.indexOf(item);
        openLightbox(visibleIndex);
      });
    });

    if (closeBtn) closeBtn.addEventListener('click', closeLightbox);
    if (backdrop) backdrop.addEventListener('click', closeLightbox);
    if (prevBtn) prevBtn.addEventListener('click', () => navigate(-1));
    if (nextBtn) nextBtn.addEventListener('click', () => navigate(1));

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (lightbox.hasAttribute('hidden')) return;

      if (e.key === 'Escape') {
        closeLightbox();
      } else if (e.key === 'ArrowLeft') {
        navigate(-1);
      } else if (e.key === 'ArrowRight') {
        navigate(1);
      } else if (e.key === 'Tab') {
        // Focus trap
        e.preventDefault();
        const active = document.activeElement;
        const idx = focusableEls.indexOf(active);
        const nextIdx = e.shiftKey
          ? (idx <= 0 ? focusableEls.length - 1 : idx - 1)
          : (idx >= focusableEls.length - 1 ? 0 : idx + 1);
        focusableEls[nextIdx].focus();
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initGaleri);
  document.addEventListener('astro:after-swap', initGaleri);
</script>
