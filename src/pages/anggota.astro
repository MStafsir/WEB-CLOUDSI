---
/**
 * anggota.astro
 * Halaman Anggota — daftar lengkap profil anggota angkatan
 * Data: dari file lokal src/data/members-data.ts
 * Fallback: Supabase via getMembers() jika data lokal kosong
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PageTransition from '../components/layout/PageTransition.astro';
import MemberCard from '../components/ui/MemberCard.astro';
import { MEMBERS_DATA } from '../data/members-data';
import { getMembers } from '../lib/supabase';

// Gunakan data lokal. Jika kosong, fallback ke Supabase.
const supabaseMembers = await getMembers();
const members = supabaseMembers.length > 0 ? supabaseMembers : MEMBERS_DATA;

// Data sudah diurutkan di members-data.ts:
// Pengurus Inti → DEV (Srilintang) → Anggota by NIM ascending
// Tidak perlu sort ulang.
const sortedMembers = members;
---

<BaseLayout title="Anggota" description="Anggota Cloudsi Connect — Kenali setiap anggota keluarga besar Sistem Informasi Universitas Tanjungpura.">
  <Header />
  <PageTransition>
    <main id="main-content">
      
      <!-- 40vh Hero Section -->
      <section class="anggota-hero" aria-label="Hero Anggota">
        <div class="anggota-hero-content fade-in">
          <h1 class="hero-title">Anggota Cloudsi</h1>
          <p class="hero-counter">76 Jiwa &middot; Satu Angkatan</p>
        </div>
      </section>

      <!-- Directory Section -->
      <section class="anggota-directory section-pad">
        <div class="container-main">
          
          <!-- Search & Filter Bar (Glass Style) -->
          <div class="search-filter-bar glass fade-in">
            <div class="search-wrap">
              <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
              <input type="text" id="member-search" class="search-input" placeholder="Cari berdasarkan nama atau panggilan..." />
            </div>
            
            <div class="filter-wrap">
              <select id="member-role-filter" class="filter-select">
                <option value="Semua">Semua Peran</option>
                <option value="Pengurus">Pengurus Inti</option>
                <option value="Anggota">Anggota Biasa</option>
              </select>
              <svg class="dropdown-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </div>
          </div>

          <!-- Grid Anggota -->
          <div class="members-grid fade-in" id="members-grid">
            {sortedMembers.map((member) => (
              <div 
                class="member-item" 
                data-name={member.full_name.toLowerCase()} 
                data-nickname={(member.nickname || '').toLowerCase()} 
                data-role={member.role}
              >
                <MemberCard member={member} />
              </div>
            ))}
          </div>

          <!-- Empty State -->
          <div class="empty-state" id="empty-state" style="display: none;">
            <p>Tidak ada anggota yang sesuai dengan pencarian Anda.</p>
          </div>

        </div>
      </section>
    </main>
  </PageTransition>
  <Footer />
</BaseLayout>

<style>
  /* Hero */
  .anggota-hero {
    height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    text-align: center;
  }

  .anggota-hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 10;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: var(--font-size-h1);
    color: white;
    margin: 0;
  }

  .hero-counter {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--color-accent-gold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Search & Filter Bar */
  .search-filter-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1rem;
    border-radius: 16px;
    margin-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .search-filter-bar {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.5rem;
    }
  }

  .search-wrap {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .search-icon {
    position: absolute;
    left: 1rem;
    width: 20px;
    height: 20px;
    color: hsla(0, 0%, 100%, 0.4);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    background: hsla(0, 0%, 100%, 0.05);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.8rem 1rem 0.8rem 3rem;
    color: white;
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    transition: border-color var(--duration-fast) var(--ease-glass), box-shadow var(--duration-fast);
  }

  .search-input::placeholder {
    color: hsla(0, 0%, 100%, 0.4);
  }

  .search-input:focus {
    border-color: var(--color-water-light);
    box-shadow: 0 0 0 3px hsla(190, 65%, 55%, 0.15);
  }

  .filter-wrap {
    position: relative;
    min-width: 200px;
  }

  .filter-select {
    width: 100%;
    appearance: none;
    background: hsla(0, 0%, 100%, 0.05);
    border: 1px solid var(--glass-border);
    border-radius: 12px;
    padding: 0.8rem 2.5rem 0.8rem 1.2rem;
    color: white;
    font-family: var(--font-body);
    font-size: 0.95rem;
    outline: none;
    cursor: pointer;
    transition: border-color var(--duration-fast) var(--ease-glass);
  }

  .filter-select option {
    background: var(--color-sky-deep);
    color: white;
  }

  .filter-select:focus {
    border-color: var(--color-water-light);
  }

  .dropdown-icon {
    position: absolute;
    right: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: hsla(0, 0%, 100%, 0.6);
    pointer-events: none;
  }

  /* Grid Anggota */
  .members-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  @media (min-width: 768px) {
    .members-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .members-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .member-item {
    transition: opacity 0.4s var(--ease-water), transform 0.4s var(--ease-water);
  }

  .empty-state {
    text-align: center;
    padding: 4rem 1rem;
    font-family: var(--font-body);
    color: hsla(0, 0%, 100%, 0.6);
    font-size: 1.1rem;
  }
</style>

<script is:inline>
  function initAnggotaDirectory() {
    const searchInput = document.getElementById('member-search');
    const roleSelect = document.getElementById('member-role-filter');
    const memberItems = document.querySelectorAll('.member-item');
    const emptyState = document.getElementById('empty-state');
    let debounceTimer;

    const pengurusRoles = ['Ketua', 'Wakil Ketua', 'Sekretaris', 'Bendahara'];

    function filterMembers() {
      const query = searchInput.value.toLowerCase().trim();
      const roleFilter = roleSelect.value;
      let visibleCount = 0;

      memberItems.forEach(item => {
        const name = item.getAttribute('data-name') || '';
        const nickname = item.getAttribute('data-nickname') || '';
        const role = item.getAttribute('data-role') || '';

        const matchesQuery = name.includes(query) || nickname.includes(query);
        let matchesRole = true;

        if (roleFilter === 'Pengurus') {
          matchesRole = pengurusRoles.includes(role);
        } else if (roleFilter === 'Anggota') {
          matchesRole = role === 'Anggota';
        }

        if (matchesQuery && matchesRole) {
          item.style.display = 'block';
          // Force a reflow slightly to trigger fade in if we wanted to
          item.style.opacity = '1';
          item.style.transform = 'scale(1)';
          visibleCount++;
        } else {
          item.style.display = 'none';
          item.style.opacity = '0';
          item.style.transform = 'scale(0.95)';
        }
      });

      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(filterMembers, 300);
      });
    }

    if (roleSelect) {
      roleSelect.addEventListener('change', filterMembers);
    }

    // Mobile specific: Tap to toggle hover panel handling
    // Close active panel if clicking anywhere else
    document.addEventListener('click', (e) => {
      const isMobile = window.matchMedia('(hover: none)').matches;
      if (!isMobile) return;

      const card = e.target.closest('[data-member-card]');
      const activeCards = document.querySelectorAll('[data-member-card].is-active');

      // If we clicked a card
      if (card) {
        const isActive = card.classList.contains('is-active');
        
        // Remove active class from all first
        activeCards.forEach(c => c.classList.remove('is-active'));
        
        // If it wasn't active, activate it.
        // Also prevent default Link behavior if it's the first click
        if (!isActive) {
          card.classList.add('is-active');
        }
      } else {
        // Remove active from everywhere if clicking outside
        activeCards.forEach(c => c.classList.remove('is-active'));
      }
    });
  }

  // Init on load
  document.addEventListener('DOMContentLoaded', initAnggotaDirectory);
  document.addEventListener('astro:after-swap', initAnggotaDirectory);
</script>
