---
/**
 * index.astro
 * Beranda yang mengassemble semua komponen secara berurutan.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import PageTransition from '../components/layout/PageTransition.astro';

import Hero from '../components/sections/Hero.astro';
import StatsSection from '../components/sections/StatsSection.astro';
import MemberPreview from '../components/sections/MemberPreview.astro';
import { getMembers } from '../lib/supabase';
import { MEMBERS_DATA } from '../data/members-data';

const supabaseMembers = await getMembers();
const members = supabaseMembers.length > 0 ? supabaseMembers : MEMBERS_DATA;

// Feature 6 anggota (1 Ketua + 5 pertama yang bukan ketua)
const ketua = members.find(m => m.role === 'Ketua');
const rest = members.filter(m => m.role !== 'Ketua').slice(0, 5);
const featuredMembers = [ketua, ...rest].filter(Boolean);
---

<BaseLayout title="Beranda" description="Beranda Cloudsi Connect — Platform Profil Angkatan Sistem Informasi Universitas Tanjungpura">
  <Header />

  <PageTransition>
    <main id="main-content">
      <!-- 1. Hero -->
      <Hero />
      
      <!-- 2. Stats Section -->
      <StatsSection />
      
      <!-- 3. Member Preview -->
      <MemberPreview members={featuredMembers} />

      <!-- 4. Section teaser Galeri Placeholder -->
      <section class="gallery-teaser section-pad">
        <div class="container-main text-center">
          <div class="teaser-grid">
            <div class="teaser-item">
               <img src="https://res.cloudinary.com/demo/image/upload/ar_1:1,c_fill,h_400/v1612456488/sample.jpg" alt="Galeri 1" width="400" height="400" loading="lazy" />
               <div class="teaser-overlay"></div>
            </div>
            <div class="teaser-item hidden-mobile">
               <img src="https://res.cloudinary.com/demo/image/upload/ar_1:1,c_fill,h_400/v1612456494/cld-sample.jpg" alt="Galeri 2" width="400" height="400" loading="lazy" />
               <div class="teaser-overlay"></div>
            </div>
            <div class="teaser-item hidden-tablet">
               <img src="https://res.cloudinary.com/demo/image/upload/ar_1:1,c_fill,h_400/v1612456491/cld-sample-4.jpg" alt="Galeri 3" width="400" height="400" loading="lazy" />
               <div class="teaser-overlay"></div>
            </div>
          </div>
          <a href="/galeri" class="gallery-cta-link">Momen Cloudsi &rarr;</a>
        </div>
      </section>
    </main>
  </PageTransition>

  <!-- 5. Footer -->
  <Footer />
</BaseLayout>

<style>
  .text-center { text-align: center; }

  .gallery-teaser {
    position: relative;
    z-index: 10;
  }

  .teaser-grid {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .teaser-item {
    position: relative;
    width: 250px;
    aspect-ratio: 1/1;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
  }

  .teaser-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .teaser-overlay {
    position: absolute;
    inset: 0;
    background: var(--glass-bg);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .gallery-cta-link {
    display: inline-block;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    color: white;
    text-decoration: none;
    border-bottom: 1px solid var(--color-water-light);
    padding-bottom: 4px;
    transition: color 0.3s ease;
  }

  .gallery-cta-link:hover {
    color: var(--color-water-light);
  }

  @media(max-width: 768px) {
    .hidden-tablet { display: none; }
  }

  @media(max-width: 480px) {
    .hidden-mobile { display: none; }
  }
</style>
