---
/**
 * BaseLayout.astro
 * Layout utama Cloudsi Connect — head, meta, fonts, canvas, slot
 * Props: title (wajib), description, ogImage
 * Dependencies: tokens.css, global.css, WaterRipple.astro, ViewTransitions
 */

import { ClientRouter } from 'astro:transitions';
import WaterRipple from '../components/canvas/WaterRipple.astro';
import Preloader from '../components/ui/Preloader.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  keywords?: string;
}

const {
  title = "Cloudsi | Sistem Informasi Untan", 
  description = "Dalam satu ruang kami adalah keluarga besar Sistem Informasi Universitas Tanjungpura, penggerak teknologi masa depan.",
  ogImage = "/logo-angkatan-25.png",
  keywords = "Cloudsi, Angkatan SI, Website Angkatan, Profil Mahasiswa",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://cloudsi.vercel.app');
const fullTitle = title;
---

<!DOCTYPE html>
<html lang="id" dir="ltr">
  <head>
    <!-- ============================================
         META — Charset, Viewport, Theme
         ============================================ -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="hsl(210, 60%, 6%)" />
    <meta name="color-scheme" content="dark" />

    <!-- ============================================
         SEO — Title, Description, Canonical
         ============================================ -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalUrl.href} />

    <!-- ============================================
         OPEN GRAPH — Social sharing meta
         ============================================ -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site ?? 'https://cloudsi.vercel.app')} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:site_name" content="Cloudsi" />
    <meta property="og:locale" content="id_ID" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site ?? 'https://cloudsi.vercel.app')} />

    <!-- ============================================
         IMPORT MAP — OGL CDN
         ============================================ -->
    <script type="importmap">
      {
        "imports": {
          "ogl": "https://unpkg.com/ogl"
        }
      }
    </script>

    <!-- ============================================
         FONTS — Preconnect + Preload Google Fonts
         Cormorant Garamond: 300, 400, 600
         Plus Jakarta Sans: 300–700
         ============================================ -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap"
      />
    </noscript>

    <!-- ============================================
         STYLES — Design Tokens + Global CSS
         ============================================ -->
    <link rel="stylesheet" href="/src/styles/global.css" />

    <!-- ============================================
         PRELOAD — Video background agar mulai download sedini mungkin
         ============================================ -->
    <link rel="preload" href="/bg-hero.mp4" as="video" type="video/mp4" />

    <!-- ============================================
         FAVICON
         ============================================ -->
    <link rel="icon" type="image/png" href="/logo-angkatan-25.png" />
    <link rel="apple-touch-icon" href="/logo-angkatan-25.png" />

    <!-- ============================================
         ASTRO VIEW TRANSITIONS (ClientRouter in v5)
         ============================================ -->
    <ClientRouter />
  </head>

  <body>
    <!-- Preloader — Muat semua aset kritis sebelum website ditampilkan -->
    <Preloader />

    <!-- Global Looping Background Video -->
    <div class="fixed inset-0 w-full h-full z-[-1] pointer-events-none">
      <video id="bg-hero-video" src="/bg-hero.mp4" autoplay loop muted playsinline preload="auto" class="absolute inset-0 w-full h-full object-cover"></video>
      <div class="absolute inset-0 bg-[hsla(210,60%,6%,0.6)] backdrop-blur-[2px]"></div>
    </div>

    <!-- WebGL Water Ripple Canvas — fixed, z-0, pointer-events: none -->
    <WaterRipple />

    <!-- Main Content — z-10 agar di atas canvas -->
    <div class="relative z-10">
      <slot />
    </div>

    <!-- ============================================
         LENIS SMOOTH SCROLL — Inisialisasi global
         ============================================ -->
    <script>
      /**
       * Timeout wrapper untuk dynamic import — mencegah Vite 504
       * dari memblokir inisialisasi Lenis selamanya
       */
      function importWithTimeout<T>(importFn: () => Promise<T>, ms: number = 5000): Promise<T> {
        return Promise.race([
          importFn(),
          new Promise<never>((_, reject) =>
            setTimeout(() => reject(new Error(`Import timeout after ${ms}ms`)), ms)
          )
        ]);
      }

      async function initLenis() {
        const prefersReduced = window.matchMedia(
          '(prefers-reduced-motion: reduce)'
        ).matches;
        
        // Mobile override: jika < 768px, nonaktifkan Lenis untuk native scroll
        const isMobile = window.innerWidth < 768;
        if (prefersReduced || isMobile) return;

        try {
          const [{ default: Lenis }, { gsap }, { ScrollTrigger }] = await Promise.all([
            importWithTimeout(() => import('lenis')),
            importWithTimeout(() => import('gsap')),
            importWithTimeout(() => import('gsap/ScrollTrigger'))
          ]);

          gsap.registerPlugin(ScrollTrigger);

          const lenis = new Lenis({
            duration: 1.4,
            easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            wheelMultiplier: 1.2,
            touchMultiplier: 1.5,
          });

          // Integrasi GSAP ScrollTrigger
          lenis.on('scroll', ScrollTrigger.update);
          gsap.ticker.add((time: number) => lenis.raf(time * 1000));
          gsap.ticker.lagSmoothing(0);

          // Cleanup on page transition
          const cleanup = () => {
            lenis.destroy();
            ScrollTrigger.getAll().forEach(t => t.kill());
            document.removeEventListener('astro:before-swap', cleanup);
          };
          document.addEventListener('astro:before-swap', cleanup);
        } catch (err) {
          console.warn('[Cloudsi] Lenis/GSAP init gagal (Vite cache issue?):', err);
          // Browser native scroll akan tetap berfungsi tanpa Lenis
        }
      }

      document.addEventListener('DOMContentLoaded', initLenis);
      document.addEventListener('astro:after-swap', initLenis);
    </script>

    <!-- ============================================
         GLOBAL FADE-IN OBSERVER
         Adds .is-visible to .fade-in elements when they enter viewport
         ============================================ -->
    <script>
      function initFadeInObserver() {
        const fadeEls = document.querySelectorAll('.fade-in');
        if (!fadeEls.length) return;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

        fadeEls.forEach(el => observer.observe(el));
      }

      document.addEventListener('DOMContentLoaded', initFadeInObserver);
      document.addEventListener('astro:after-swap', initFadeInObserver);
    </script>

    <!-- ============================================
         GLOBAL CONTENT SAFETY NET (is:inline = KEBAL VITE)
         
         MENGAPA INI DIPERLUKAN:
         Komponen seperti Hero.astro, StatsSection.astro, MemberPreview.astro
         menggunakan <script> (bukan is:inline). Astro mengubah ini menjadi
         <script type="module"> yang DIPROSES oleh Vite.
         
         Jika Vite 504 (cache corruption), MODULE SCRIPT SELURUHNYA gagal load.
         Akibatnya, kode showAll() fallback di dalam catch block TIDAK PERNAH
         BISA JALAN — karena file .js nya sendiri yang gagal di-serve.
         
         Solusi: inline script ini KEBAL Vite dan akan paksa tampilkan
         semua konten setelah 5 detik jika masih tersembunyi.
         ============================================ -->
    <script is:inline>
      setTimeout(function() {
        // Daftar selector elemen yang diketahui mulai dengan opacity: 0
        // dan bergantung pada GSAP module scripts untuk ditampilkan
        var selectors = [
          '[data-hero-badge]',
          '[data-hero-heading]',
          '[data-hero-anim]',
          '.hero-badge',
          '.hero-heading', 
          '.hero-subheading',
          '.hero-desc',
          '.hero-cta',
          '.member-preview-card',
          '.tentang-title',
          '.tentang-sub',
          '[data-tentang-anim]',
          '[data-event-card]',
          '.stack-card',
          '.photo-frame',
          '[data-stat-target]'
        ];

        var allEls = document.querySelectorAll(selectors.join(','));
        var fixed = 0;
        for (var i = 0; i < allEls.length; i++) {
          var el = allEls[i];
          var computed = window.getComputedStyle(el);
          // Hanya paksa tampilkan jika masih tersembunyi
          if (computed.opacity === '0' || parseFloat(computed.opacity) < 0.1) {
            el.style.opacity = '1';
            el.style.transform = 'none';
            el.style.visibility = 'visible';
            fixed++;
          }
        }
        if (fixed > 0) {
          console.warn('[Cloudsi] Global safety net: force-showed ' + fixed + ' hidden elements after 5s');
        }
      }, 5000);
    </script>
  </body>
</html>
