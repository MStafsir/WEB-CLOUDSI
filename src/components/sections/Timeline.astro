---
/**
 * Timeline.astro
 * Komponen timeline vertikal — alternating cards (desktop), kiri (mobile)
 * Garis tengah gradient, dot pulsing, scroll-triggered slide-in
 * Dependencies: global.css (tokens), supabase.ts (getTimeline), GSAP ScrollTrigger
 */
import type { TimelineEntry } from '../../types/index';

interface Props {
  entries: TimelineEntry[];
}

const { entries } = Astro.props;

// Fallback jika kosong
const timelineData: TimelineEntry[] = entries.length > 0
  ? entries
  : [{
      id: 0,
      date: '2025-08-04',
      title: 'Cloudsi Berdiri',
      description: 'Hari pertama angkatan Sistem Informasi 2025 resmi terbentuk.',
      order_index: 0,
    }];

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('id-ID', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<div class="timeline-wrapper" id="timeline-component">
  <!-- Garis vertikal tengah -->
  <div class="timeline-line" id="timeline-line" aria-hidden="true"></div>

  {timelineData.map((entry, index) => (
    <div
      class:list={['timeline-entry', index % 2 === 0 ? 'entry-left' : 'entry-right']}
      data-timeline-entry
    >
      <!-- Dot pada garis -->
      <div class="timeline-dot" data-timeline-dot aria-hidden="true"></div>

      <!-- Card -->
      <div class="timeline-card glass" data-timeline-card>
        <time class="timeline-date" datetime={entry.date}>
          {formatDate(entry.date)}
        </time>
        <h3 class="timeline-title">{entry.title}</h3>
        {entry.description && (
          <p class="timeline-desc">{entry.description}</p>
        )}
      </div>
    </div>
  ))}
</div>

<style>
  .timeline-wrapper {
    position: relative;
    padding: 3rem 0;
    max-width: 900px;
    margin: 0 auto;
  }

  /* Garis vertikal tengah */
  .timeline-line {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      180deg,
      var(--color-water-light) 0%,
      var(--color-accent-gold) 100%
    );
    transform: translateX(-50%);
    transform-origin: top;
    /* Animasi: scaleY 0→1 akan di-drive oleh GSAP, tapi default visible */
    will-change: transform;
  }

  /* Entry row */
  .timeline-entry {
    position: relative;
    display: flex;
    align-items: flex-start;
    margin-bottom: 3rem;
    width: 100%;
  }

  /* Desktop alternating */
  .entry-left {
    justify-content: flex-start;
    padding-right: calc(50% + 2rem);
  }

  .entry-right {
    justify-content: flex-end;
    padding-left: calc(50% + 2rem);
  }

  /* Dot */
  .timeline-dot {
    position: absolute;
    left: 50%;
    top: 1.2rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-water-light);
    transform: translateX(-50%) scale(0);
    box-shadow: 0 0 0 4px hsla(190, 65%, 55%, 0.2);
    transition: transform var(--duration-normal) var(--ease-water);
    will-change: transform;
  }

  .timeline-dot.visible {
    transform: translateX(-50%) scale(1);
    animation: dotPulse 2.5s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { box-shadow: 0 0 0 4px hsla(190, 65%, 55%, 0.2); }
    50% { box-shadow: 0 0 0 8px hsla(190, 65%, 55%, 0.08); }
  }

  /* Card */
  .timeline-card {
    max-width: 380px;
    padding: 1.5rem;
    opacity: 0;
    will-change: transform, opacity;
  }

  .entry-left .timeline-card {
    transform: translateX(-40px);
  }

  .entry-right .timeline-card {
    transform: translateX(40px);
  }

  .timeline-card.visible {
    opacity: 1;
    transform: translateX(0);
    transition: opacity var(--duration-slow) var(--ease-water),
                transform var(--duration-slow) var(--ease-water);
  }

  /* Card content */
  .timeline-date {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-accent-gold);
    margin-bottom: 0.5rem;
  }

  .timeline-title {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 600;
    color: white;
    margin: 0 0 0.5rem 0;
    line-height: 1.3;
  }

  .timeline-desc {
    font-family: var(--font-body);
    font-size: var(--font-size-body);
    color: hsla(0, 0%, 100%, 0.7);
    line-height: 1.7;
    margin: 0;
  }

  /* ====== MOBILE: garis di kiri, semua card di kanan ====== */
  @media (max-width: 768px) {
    .timeline-line {
      left: 20px;
      transform: none;
    }

    .timeline-entry {
      padding-left: 48px;
      padding-right: 0;
    }

    .entry-left,
    .entry-right {
      justify-content: flex-start;
      padding-left: 48px;
      padding-right: 0;
    }

    .timeline-dot {
      left: 20px;
    }

    .timeline-card {
      max-width: 100%;
    }

    .entry-left .timeline-card,
    .entry-right .timeline-card {
      transform: translateX(30px);
    }

    .timeline-card.visible {
      transform: translateX(0);
    }
  }
</style>

<script is:inline>
  (function() {
    function initTimeline() {
      var cards = document.querySelectorAll('[data-timeline-card]');
      var dots = document.querySelectorAll('[data-timeline-dot]');
      var line = document.getElementById('timeline-line');

      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) {
        cards.forEach(function(c) { c.classList.add('visible'); });
        dots.forEach(function(d) { d.classList.add('visible'); });
        return;
      }

      // Garis: animate scaleY via GSAP
      if (line) {
        Promise.all([
          import('https://cdn.jsdelivr.net/npm/gsap@3.12.5/+esm'),
          import('https://cdn.jsdelivr.net/npm/gsap@3.12.5/ScrollTrigger.js/+esm')
        ]).then(function(modules) {
          var gsap = modules[0].gsap || modules[0].default;
          var ScrollTrigger = modules[1].ScrollTrigger || modules[1].default;
          gsap.registerPlugin(ScrollTrigger);

          gsap.fromTo(line,
            { scaleY: 0 },
            {
              scaleY: 1, ease: 'none',
              scrollTrigger: {
                trigger: '#timeline-component',
                start: 'top 80%',
                end: 'bottom 60%',
                scrub: 1,
              },
            }
          );
        }).catch(function(err) {});
      }

      // Cards & dots: IntersectionObserver
      var observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.2 });

      cards.forEach(function(c) { observer.observe(c); });
      dots.forEach(function(d) { observer.observe(d); });
    }

    document.addEventListener('DOMContentLoaded', initTimeline);
    document.addEventListener('astro:after-swap', initTimeline);
  })();
</script>
