---
/**
 * MemberPreview.astro
 * Menampilkan preview 6 anggota featured dengan animated gradient borders
 */
import type { Member } from '../../types/index';

interface Props {
  members: Member[];
}

const { members } = Astro.props;
---

<section class="member-preview-section section-pad" id="preview-members">
  <div class="container-main">
    
    <div class="section-header">
      <h2 class="section-title">Wajah Cloudsi</h2>
      <p class="section-sub">75 Anggota &middot; Sistem Informasi &middot; 2025</p>
    </div>

    <div class="member-grid">
      {members.map((member, index) => (
        <a 
          href={`/anggota#${member.id}`} 
          class="member-preview-card"
          style={`--card-delay: ${index * 0.1}s; --card-hue: ${(index * 50 + 190) % 360}; view-transition-name: member-card-${member.id}`}
        >
          <!-- Animated border glow -->
          <div class="card-border-glow"></div>
          
          <!-- Card inner content -->
          <div class="card-inner">
            <!-- Gambar lokal -->
            <img 
              src={member.photo_url}
              alt={`Foto ${member.full_name}`}
              loading={index < 2 ? "eager" : "lazy"} 
              decoding="async"
              class="member-img"
              width="400"
              height="533"
            />

            <!-- Gradient Overlay -->
            <div class="card-overlay"></div>

            <!-- Role Badge -->
            <div class="glass-badge">{member.role}</div>

            <!-- Name -->
            <div class="card-content">
              <h3 class="member-name">{member.full_name}</h3>
              {member.nickname && <span class="member-nick">({member.nickname})</span>}
            </div>
          </div>
        </a>
      ))}
    </div>

    <div class="cta-wrapper">
      <a href="/anggota" class="cta-link">
        <span>Lihat Semua Anggota</span>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .member-preview-section {
    position: relative;
    z-index: 10;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--font-size-h2);
    font-weight: 300;
    color: white;
    margin: 0;
  }

  .section-sub {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0, 0%, 100%, 0.5);
    letter-spacing: 0.1em;
    margin-top: 0.5rem;
    text-transform: uppercase;
  }

  .member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  @media(max-width: 1024px) {
    .member-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media(max-width: 640px) {
    .member-grid { grid-template-columns: 1fr; }
  }

  /* === CARD WITH ANIMATED GRADIENT BORDER === */
  .member-preview-card {
    position: relative;
    aspect-ratio: 3/4;
    border-radius: 16px;
    display: block;
    text-decoration: none;
    padding: 2px; /* Space for the border glow */
    opacity: 0;
    transform: translateY(30px);
    transition: transform 0.5s var(--ease-water), opacity 0.5s var(--ease-water);
  }

  /* Animated gradient border */
  .card-border-glow {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: linear-gradient(
      135deg,
      hsla(var(--card-hue), 70%, 60%, 0.15),
      hsla(calc(var(--card-hue) + 40), 70%, 50%, 0.08),
      hsla(calc(var(--card-hue) + 80), 70%, 60%, 0.15)
    );
    background-size: 300% 300%;
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 0;
  }

  .member-preview-card:hover .card-border-glow {
    opacity: 1;
    animation: borderShimmer 3s ease infinite;
  }

  @keyframes borderShimmer {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  /* Inner content */
  .card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    transition: border-color 0.5s ease, box-shadow 0.5s ease;
  }

  .member-preview-card:hover .card-inner {
    border-color: hsla(var(--card-hue), 60%, 55%, 0.4);
    box-shadow: 
      0 0 20px hsla(var(--card-hue), 60%, 50%, 0.15),
      0 8px 32px hsla(210, 60%, 4%, 0.4),
      inset 0 1px 0 hsla(0, 0%, 100%, 0.1);
  }

  .member-preview-card:hover {
    transform: translateY(-6px) scale(1.01);
  }

  .member-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s var(--ease-water);
  }

  .member-preview-card:hover .member-img {
    transform: scale(1.05);
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, hsla(210,60%,6%,0.9) 0%, hsla(210,60%,6%,0.3) 50%, transparent 100%);
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .glass-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--glass-bg);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    border: 1px solid var(--glass-border);
    border-radius: 999px;
    padding: 0.3rem 0.85rem;
    font-family: var(--font-body);
    font-size: 0.6rem;
    font-weight: 600;
    color: white;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    pointer-events: none;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .member-preview-card:hover .glass-badge {
    background: hsla(var(--card-hue), 50%, 40%, 0.3);
    border-color: hsla(var(--card-hue), 60%, 55%, 0.4);
  }

  .card-content {
    position: absolute;
    bottom: 1.25rem;
    left: 1rem;
    right: 1rem;
    pointer-events: none;
  }

  .member-name {
    font-family: var(--font-display);
    color: white;
    font-size: 1.25rem;
    font-weight: 400;
    margin: 0;
    line-height: 1.2;
  }

  .member-nick {
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: hsla(0, 0%, 100%, 0.6);
    font-style: italic;
  }

  /* CTA */
  .cta-wrapper {
    text-align: center;
  }

  .cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-water-light);
    text-decoration: none;
    font-weight: 500;
    padding: 0.75rem 1.5rem;
    border-radius: 12px;
    border: 1px solid hsla(190, 65%, 55%, 0.2);
    background: hsla(190, 65%, 55%, 0.05);
    transition: all 0.3s ease;
  }

  .cta-link:hover {
    color: white;
    border-color: hsla(190, 65%, 55%, 0.4);
    background: hsla(190, 65%, 55%, 0.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 20px hsla(190, 65%, 55%, 0.15);
  }

  .cta-link svg {
    transition: transform 0.3s ease;
  }

  .cta-link:hover svg {
    transform: translateX(4px);
  }
</style>

<script is:inline>
  (function() {
    function initMemberPreview() {
      var cards = document.querySelectorAll('.member-preview-card');
      
      function showAll() {
        cards.forEach(function(card) {
          card.style.opacity = '1';
          card.style.transform = 'none';
        });
      }

      if (cards.length === 0) return;


    }

    document.addEventListener('DOMContentLoaded', initMemberPreview);
    document.addEventListener('astro:after-swap', initMemberPreview);
  })();
</script>
