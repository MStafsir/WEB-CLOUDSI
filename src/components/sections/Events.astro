---
/**
 * Events.astro
 * Section acara/kegiatan — timeline dan event cards
 * Dependencies: GlassCard.astro, types/index.ts
 */

import GlassCard from '../ui/GlassCard.astro';
import Button from '../ui/Button.astro';
import type { Event } from '../../types/index';

interface Props {
  events?: Event[];
}

const { events = [] } = Astro.props;
---

<section class="events section-pad" id="events-section" aria-label="Acara">
  <div class="container-main">
    <div class="events-header fade-in">
      <p class="section-eyebrow">Acara</p>
      <h2 class="section-title">
        Kegiatan <span class="text-gradient-water">terkini</span>
      </h2>
    </div>

    {events.length > 0 ? (
      <div class="events-grid fade-in">
        {events.map((event) => (
          <GlassCard tag="article" padding="sm" class="event-card">
            <div class="event-image-wrapper">
              <img
                src={event.cover_image}
                alt={event.title}
                class="event-image"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="event-info">
              <time class="event-date" datetime={event.date}>
                {new Date(event.date).toLocaleDateString('id-ID', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h3 class="event-title">{event.title}</h3>
              {event.description && (
                <p class="event-desc">{event.description}</p>
              )}
              <Button variant="ghost" size="sm" href={`/acara/${event.slug}`}>
                Selengkapnya →
              </Button>
            </div>
          </GlassCard>
        ))}
      </div>
    ) : (
      <div class="events-empty fade-in">
        <p>Informasi acara akan segera hadir.</p>
      </div>
    )}
  </div>
</section>

<style>
  .events-header {
    max-width: 600px;
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 1rem;
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--font-size-h1);
    font-weight: 300;
    color: hsla(0, 0%, 100%, 0.95);
  }

  .events-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
  }

  .event-card {
    display: flex;
    flex-direction: column;
  }

  .event-image-wrapper {
    position: relative;
    aspect-ratio: 16/9;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  .event-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-water);
  }

  .event-card:hover .event-image {
    transform: scale(1.05);
  }

  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.5rem;
  }

  .event-date {
    font-size: 0.75rem;
    color: var(--color-accent-gold);
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .event-title {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 600;
    color: hsla(0, 0%, 100%, 0.95);
  }

  .event-desc {
    font-size: 0.875rem;
    color: hsla(0, 0%, 100%, 0.5);
    line-height: 1.6;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .events-empty {
    text-align: center;
    color: hsla(0, 0%, 100%, 0.4);
    padding: 4rem 2rem;
    font-style: italic;
  }
</style>
