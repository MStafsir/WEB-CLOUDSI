---
/**
 * PageTransition.astro — FIXED v2 (SAFETY GUARD)
 * 
 * View Transition implementasi dengan safety guard untuk prevent content disappearing
 * 
 * MASALAH YANG DISELESAIKAN:
 * 1. Content hilang saat navigasi → astro:after-swap handler
 * 2. Blur filter cause invisible elements → Mobile fallback
 * 3. Scale transform stuck → Safety net force reset
 * 4. Opacity 0 stuck → Force visibility setelah transition
 * 5. Layout shift → Isolation fix
 */
---

<slot />

<style is:global>
  /* 
   * Astro View Transition hooks for Smooth Fade & Scale Effect
   * Jauh lebih ringan di GPU daripada clip-path, menghindari lag di halaman berat (Anggota).
   */

  /* OUT animation (halaman lama memudar dan sedikit menyusut) */
  @keyframes smoothFadeOut {
    from { 
      opacity: 1; 
      transform: translateY(0) scale(1);
      filter: blur(0px);
    }
    to { 
      opacity: 0; 
      transform: translateY(-20px) scale(0.98);
      filter: blur(4px);
    }
  }

  /* IN animation (halaman baru muncul dan membesar dari bawah) */
  @keyframes smoothFadeIn {
    from { 
      opacity: 0; 
      transform: translateY(30px) scale(1.02);
      filter: blur(6px);
    }
    to { 
      opacity: 1; 
      transform: translateY(0) scale(1);
      filter: blur(0px);
    }
  }

  /* Mengatur durasi dasar View Transitions */
  ::view-transition-group(root) {
    animation-duration: 700ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  ::view-transition-old(root) {
    animation: smoothFadeOut 400ms cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  
  ::view-transition-new(root) {
    animation: smoothFadeIn 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 50ms; /* Tunggu halaman lama sedikit bersembunyi */
  }

  /* Cegah elemen yang "on-top" seperti transisi dari gangguan layout */
  ::view-transition-image-pair(root) {
    isolation: auto;
  }

  /* ============================================
     SAFETY GUARD STYLES
     ============================================ */

  /* 1. Force root visibility jika transition gagal */
  :root.is-transitioning {
    opacity: 1 !important;
    visibility: visible !important;
  }

  /* 2. Ensure main content visibility setelah transition */
  main {
    opacity: 1 !important;
    visibility: visible !important;
  }

  /* 3. Fallback: jika blur menyebabkan masalah rendering */
  @supports not (filter: blur(1px)) {
    ::view-transition-new(root) {
      filter: none !important;
    }
    ::view-transition-old(root) {
      filter: none !important;
    }
  }

  /* 4. Mobile: Disable blur untuk prevent invisible content */
  @media (max-width: 768px) {
    ::view-transition-new(root) {
      filter: blur(0px) !important; /* Disable blur di mobile */
      animation: smoothFadeIn 500ms cubic-bezier(0.22, 1, 0.36, 1) both !important;
    }

    ::view-transition-old(root) {
      filter: blur(0px) !important;
      animation: smoothFadeOut 300ms cubic-bezier(0.4, 0, 0.2, 1) both !important;
    }

    /* Mobile: disable scale untuk prevent visual bugs */
    @keyframes smoothFadeOut {
      from { 
        opacity: 1; 
        transform: translateY(0) scale(1);
      }
      to { 
        opacity: 0; 
        transform: translateY(-10px) scale(1);
      }
    }

    @keyframes smoothFadeIn {
      from { 
        opacity: 0; 
        transform: translateY(10px) scale(1);
      }
      to { 
        opacity: 1; 
        transform: translateY(0) scale(1);
      }
    }
  }

  /* 5. Ensure all sections visible during transition */
  section {
    opacity: 1 !important;
    visibility: visible !important;
  }

  header, footer {
    opacity: 1 !important;
    visibility: visible !important;
  }

  /* 6. Force fade-in elements visible */
  .fade-in, [data-hero-badge], [data-hero-heading], [data-hero-anim] {
    visibility: visible !important;
  }

  /* 7. Backup: Reset transform jika stuck */
  body.transition-complete main {
    transform: none !important;
  }
</style>

<!-- Safety Guard Script — Ensure content render setelah transition -->
<script is:inline>
  (function() {
    'use strict';

    var transitionTimeout;
    var isTransitioning = false;

    // =============================================
    // HELPER FUNCTIONS
    // =============================================

    /**
     * Force render content yang invisible
     */
    function forceContentVisibility() {
      // 1. Force main visibility
      var main = document.querySelector('main');
      if (main) {
        main.style.opacity = '1';
        main.style.visibility = 'visible';
        main.style.transform = 'none';
      }

      // 2. Force all sections visible
      var sections = document.querySelectorAll('section');
      for (var i = 0; i < sections.length; i++) {
        sections[i].style.opacity = '1';
        sections[i].style.visibility = 'visible';
      }

      // 3. Force header & footer visible
      var header = document.querySelector('header');
      if (header) {
        header.style.opacity = '1';
        header.style.visibility = 'visible';
      }

      var footer = document.querySelector('footer');
      if (footer) {
        footer.style.opacity = '1';
        footer.style.visibility = 'visible';
      }

      // 4. Force fade-in elements visible
      var fadeIns = document.querySelectorAll('.fade-in, [data-hero-badge], [data-hero-heading], [data-hero-anim]');
      for (var j = 0; j < fadeIns.length; j++) {
        if (!fadeIns[j].classList.contains('is-visible')) {
          fadeIns[j].classList.add('is-visible');
        }
        fadeIns[j].style.opacity = '1';
        fadeIns[j].style.visibility = 'visible';
      }

      // 5. Reset body transform
      document.body.classList.add('transition-complete');
      document.body.style.transform = 'none';
    }

    /**
     * Start transition mark
     */
    function startTransition() {
      isTransitioning = true;
      document.documentElement.classList.add('is-transitioning');

      // Clear existing timeout
      if (transitionTimeout) {
        clearTimeout(transitionTimeout);
      }

      // Safety net: 1 detik, force visibility jika transition hang
      transitionTimeout = setTimeout(function() {
        console.warn('[Cloudsi PageTransition] Safety net triggered after 1s');
        forceContentVisibility();
      }, 1000);
    }

    /**
     * End transition mark
     */
    function endTransition() {
      isTransitioning = false;
      document.documentElement.classList.remove('is-transitioning');

      // Clear timeout
      if (transitionTimeout) {
        clearTimeout(transitionTimeout);
      }

      // Force visibility setelah DOM swap
      setTimeout(function() {
        forceContentVisibility();
      }, 50);

      // Extra safety: 500ms after swap
      setTimeout(function() {
        forceContentVisibility();
      }, 500);
    }

    /**
     * Monitor DOM untuk ensure content tetap visible
     */
    function monitorContentVisibility() {
      var checkInterval = setInterval(function() {
        if (isTransitioning) {
          var main = document.querySelector('main');
          if (main) {
            var computed = window.getComputedStyle(main);
            if (computed.opacity === '0' || computed.visibility === 'hidden') {
              console.warn('[Cloudsi PageTransition] Content invisible detected, forcing visible');
              forceContentVisibility();
            }
          }
        }
      }, 100);

      // Stop monitoring setelah 3 detik
      setTimeout(function() {
        clearInterval(checkInterval);
      }, 3000);
    }

    // =============================================
    // EVENT LISTENERS
    // =============================================

    // 1. Before preparation (sebelum transition dimulai)
    document.addEventListener('astro:before-preparation', function() {
      startTransition();
    });

    // 2. After swap (setelah DOM di-replace)
    document.addEventListener('astro:after-swap', function() {
      endTransition();
      monitorContentVisibility();
    });

    // 3. Before swap (alternative hook untuk compatibility)
    document.addEventListener('astro:before-swap', function() {
      startTransition();
    });

    // =============================================
    // FALLBACK: Jika View Transition API tidak support
    // =============================================

    if (!document.startViewTransition) {
      document.addEventListener('astro:after-swap', function() {
        // Untuk browser yang tidak support View Transition API
        forceContentVisibility();
      });
    }

    // =============================================
    // INIT: Ensure initial content visible
    // =============================================

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        forceContentVisibility();
      });
    } else {
      forceContentVisibility();
    }

    // =============================================
    // ABSOLUTE SAFETY NET: 8 detik
    // =============================================

    setTimeout(function() {
      forceContentVisibility();
    }, 8000);

  })();
</script>
