---
/**
 * PageTransition.astro
 * View Transition implementasi wiping water wipe 
 */
---

<slot />

<style is:global>
  /* 
   * Astro View Transition hooks for Smooth Fade & Scale Effect
   * Jauh lebih ringan di GPU daripada clip-path, menghindari lag di halaman berat (Anggota).
   */

  /* OUT animation (halaman lama memudar dan sedikit menyusut) */
  @keyframes smoothFadeOut {
    from { 
      opacity: 1; 
      transform: translateY(0) scale(1);
      filter: blur(0px);
    }
    to { 
      opacity: 0; 
      transform: translateY(-20px) scale(0.98);
      filter: blur(4px);
    }
  }

  /* IN animation (halaman baru muncul dan membesar dari bawah) */
  @keyframes smoothFadeIn {
    from { 
      opacity: 0; 
      transform: translateY(30px) scale(1.02);
      filter: blur(6px);
    }
    to { 
      opacity: 1; 
      transform: translateY(0) scale(1);
      filter: blur(0px);
    }
  }

  /* Mengatur durasi dasar View Transitions */
  ::view-transition-group(root) {
    animation-duration: 700ms;
    animation-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
  }

  ::view-transition-old(root) {
    animation: smoothFadeOut 400ms cubic-bezier(0.4, 0, 0.2, 1) both;
  }
  
  ::view-transition-new(root) {
    animation: smoothFadeIn 700ms cubic-bezier(0.22, 1, 0.36, 1) both;
    animation-delay: 50ms; /* Tunggu halaman lama sedikit bersembunyi */
  }

  /* Cegah elemen yang "on-top" seperti transisi dari gangguan layout */
  ::view-transition-image-pair(root) {
    isolation: auto;
  }
</style>
