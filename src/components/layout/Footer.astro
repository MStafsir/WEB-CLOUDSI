---
/**
 * Footer.astro
 * Footer layout dengan gradient background dan typography yang presisi
 */
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: "/", label: "Beranda" },
  { href: "/tentang", label: "Tentang" },
  { href: "/galeri", label: "Galeri" },
  { href: "/anggota", label: "Anggota" },
  { href: "/acara", label: "Acara" },
  { href: "/kontak", label: "Kontak" },
];
---

<footer class="main-footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-col brand-col">
        <div class="footer-brand-logo">
          <img
            src="/logo-angkatan-25.webp"
            alt="Logo Cloudsi"
            class="footer-logo-img"
          />
          <h2 class="footer-logo-text">CLOUDSI</h2>
        </div>
        <p class="brand-desc">
          Website resmi CloudSI - Angkatan 2025 Program Studi Sistem Informasi
          Universitas Tanjungpura. Platform terpadu untuk saling terhubung dan
          berbagi momen bersama Keluarga Besar Sistem Informasi. Rumah kami
          untuk tumbuh bersama.
        </p>
        <address class="brand-address">
          <strong>Fakultas MIPA, UNTAN</strong><br />
          Jl. Daya Nasional, Pontianak 78124<br />
          Kalimantan Barat
        </address>
      </div>

      <div class="footer-col nav-col">
        <h3 class="col-title">Navigasi</h3>
        <ul class="footer-links">
          {
            navLinks.map((link) => (
              <li>
                <a href={link.href}>{link.label}</a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="footer-col social-col">
        <h3 class="col-title">Sosial Media</h3>
        <ul class="footer-links">
          <li>
            <a
              href="https://www.instagram.com/cloudsi.25?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
              target="_blank"
              rel="noopener noreferrer">Instagram Angkatan</a
            >
          </li>
          <li><a href="/kontak">Hubungi Kami</a></li>
        </ul>
      </div>

      <div class="footer-col official-col">
        <h3 class="col-title">Tautan Resmi</h3>
        <ul class="footer-links">
          <li>
            <a
              href="https://untan.ac.id/"
              target="_blank"
              rel="noopener noreferrer">UNTAN Official</a
            >
          </li>
          <li>
            <a
              href="https://mipa.untan.ac.id/#"
              target="_blank"
              rel="noopener noreferrer">Fakultas MIPA</a
            >
          </li>
          <li>
            <a
              href="https://sisfo.untan.ac.id/"
              target="_blank"
              rel="noopener noreferrer">Sistem Informasi UNTAN</a
            >
          </li>
          <li>
            <a
              href="https://satu.untan.ac.id/gate/login"
              target="_blank"
              rel="noopener noreferrer">SATU UNTAN</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>
        &copy; {currentYear} Made with <span class="heart">❤️</span>by CloudSI —
        Sistem Informasi UNTAN
      </p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    width: 100%;
    margin-top: 5rem;
    padding-top: 4rem;
    background: linear-gradient(
      180deg,
      transparent 0%,
      var(--color-sky-deep) 100%
    );
    position: relative;
    z-index: 10;
  }

  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .brand-address {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: hsla(0, 0%, 100%, 0.5);
    font-style: normal;
    margin-top: 1rem;
  }

  .brand-address strong {
    color: white;
  }

  .footer-brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    border-radius: 6px;
    object-fit: contain;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: 0.2em;
    color: white;
    margin: 0;
  }

  .brand-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: hsla(0, 0%, 100%, 0.5);
    margin: 0;
  }

  .col-title {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    margin-top: 0;
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0, 0%, 100%, 0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-water-light);
  }

  .footer-bottom {
    border-top: 1px solid var(--glass-border);
    padding: 1.5rem 0;
    text-align: left;
  }

  .footer-bottom p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0, 0%, 100%, 0.5);
    margin: 0;
  }

  /* Mobile Stack */
  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .footer-bottom {
      text-align: center;
    }

    .footer-links {
      align-items: center;
    }
  }
</style>
