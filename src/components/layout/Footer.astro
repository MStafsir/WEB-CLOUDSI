---
/**
 * Footer.astro
 * Footer layout dengan gradient background dan typography yang presisi
 */
const currentYear = new Date().getFullYear();

const navLinks = [
  { href: '/', label: 'Beranda' },
  { href: '/tentang', label: 'Tentang' },
  { href: '/galeri', label: 'Galeri' },
  { href: '/anggota', label: 'Anggota' },
  { href: '/acara', label: 'Acara' },
  { href: '/kontak', label: 'Kontak' },
];
---

<footer class="main-footer">
  <div class="footer-container">
    <div class="footer-grid">
      
      <!-- Kolom 1: Logo & Desc -->
      <div class="footer-col brand-col">
        <div class="footer-brand-logo">
          <img src="https://via.placeholder.com/48" alt="Logo Cloudsi" class="footer-logo-img" />
          <h2 class="footer-logo-text">CLOUDSI</h2>
        </div>
        <p class="brand-desc">
          Platform terpadu untuk saling terhubung dan berbagi momen<br>
          bersama Keluarga Besar Sistem Informasi.
        </p>
      </div>

      <!-- Kolom 2: Navigasi Ulang -->
      <div class="footer-col nav-col">
        <h3 class="col-title">Navigasi</h3>
        <ul class="footer-links">
          {navLinks.map(link => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Kolom 3: Social Media -->
      <div class="footer-col social-col">
        <h3 class="col-title">Sosial Media</h3>
        <ul class="footer-links">
          <li><a href="https://instagram.com" target="_blank" rel="noopener noreferrer">Instagram Angkatan</a></li>
          <li><a href="/kontak">Hubungi Kami</a></li>
        </ul>
      </div>
    
    </div>

    <!-- Pemisah & Copyright -->
    <div class="footer-bottom">
      <p>&copy; 2025 Cloudsi — Sistem Informasi</p>
    </div>
  </div>
</footer>

<style>
  .main-footer {
    width: 100%;
    margin-top: 5rem;
    padding-top: 4rem;
    background: linear-gradient(180deg, transparent 0%, var(--color-sky-deep) 100%);
    position: relative;
    z-index: 10; 
  }

  .footer-container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--gutter);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    margin-bottom: 3rem;
  }

  .footer-brand-logo {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 1rem;
  }

  .footer-logo-img {
    height: 48px;
    width: auto;
    border-radius: 6px;
    object-fit: contain;
  }

  .footer-logo-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: 0.2em;
    color: white;
    margin: 0;
  }

  .brand-desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: hsla(0,0%,100%,0.5);
    margin: 0;
  }

  .col-title {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    margin-top: 0;
    margin-bottom: 1.25rem;
    letter-spacing: 0.05em;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0,0%,100%,0.5);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--color-water-light);
  }

  .footer-bottom {
    border-top: 1px solid var(--glass-border);
    padding: 1.5rem 0;
    text-align: left;
  }

  .footer-bottom p {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: hsla(0,0%,100%,0.5);
    margin: 0;
  }

  /* Mobile Stack */
  @media(max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    
    .footer-bottom {
      text-align: center;
    }
    
    .footer-links {
      align-items: center;
    }
  }
</style>
