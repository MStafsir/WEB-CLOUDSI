---
/**
 * Header.astro
 * Navigasi utama Cloudsi Connect — Bifurcated responsive morphing menu
 *
 * FIX: CSS Containing Block Trap (backdrop-filter)
 * .mobile-drawer & .mobile-backdrop dipindahkan ke LUAR <header>.
 * Keduanya kini sibling langsung di DOM level halaman, bukan child dari
 * .header-nav yang memiliki backdrop-filter (penyebab containing block baru).
 * Referensi: https://www.w3.org/TR/css-transforms-1/#containing-block-for-all-fixed
 */
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: "/", label: "Beranda" },
  { href: "/tentang", label: "Tentang" },
  { href: "/anggota", label: "Anggota" },
  { href: "/galeri", label: "Galeri" },
  { href: "/acara", label: "Acara" },
  { href: "/kontak", label: "Kontak" },
  { href: "/lagu", label: "Lagu Angkatan" },
];
---

<header class="header-nav" id="main-header">
  <div class="header-container">
    <a href="/" class="header-logo-group">
      <img
        src="/logo-angkatan-25.webp?v=update"
        alt="Logo Cloudsi"
        class="header-logo-img"
      />
      <div class="header-logo-text-group">
        <h1 class="header-logo-text">CLOUDSI</h1>
        <span class="header-logo-sub">Sistem Informasi UNTAN</span>
      </div>
    </a>

    <nav class="desktop-nav" aria-label="Desktop menu">
      <ul class="nav-list">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  "nav-link",
                  {
                    active:
                      link.href === currentPath ||
                      (link.href !== "/" && currentPath.startsWith(link.href)),
                  },
                ]}
              >
                {link.label}
                <span class="underline-hover" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      id="hamburger-btn"
      class="hamburger-btn glass-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-drawer"
    >
      <span class="line line-1"></span>
      <span class="line line-2"></span>
      <span class="line line-3"></span>
    </button>
  </div>
</header>

<div class="mobile-backdrop" id="mobile-backdrop" aria-hidden="true"></div>

<nav
  class="mobile-drawer"
  id="mobile-drawer"
  aria-label="Mobile menu"
  aria-hidden="true"
>
  <ul class="mobile-nav-list">
    {
      navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              "mobile-nav-link",
              {
                active:
                  link.href === currentPath ||
                  (link.href !== "/" && currentPath.startsWith(link.href)),
              },
            ]}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style is:global>
  :root {
    --header-height: 80px;
    --header-height-mobile: 72px;
    --nav-item-padding: 0.75rem 1rem;
    --nav-item-font-size: 1rem;
    --nav-active-color: hsl(210, 100%, 60%);
    --nav-hover-color: hsl(210, 100%, 70%);
  }

  .header-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    height: var(--header-height);
    background: linear-gradient(
      180deg,
      rgba(5, 20, 40, 0.8) 0%,
      rgba(5, 20, 40, 0.5) 100%
    );
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 998;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.5rem;
    height: 100%;
    max-width: 100%;
  }

  .header-logo-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    flex-shrink: 0;
    flex-wrap: wrap;
    transition: opacity 0.3s ease;
  }

  .header-logo-group:hover {
    opacity: 0.8;
  }

  .header-logo-img {
    width: 48px;
    height: 48px;
    object-fit: contain;
    border-radius: 8px;
  }

  .header-logo-text-group {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .header-logo-text {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #fff;
    margin: 0;
    line-height: 1;
  }

  .header-logo-sub {
    font-size: 0.65rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .desktop-nav {
    display: none;
    flex: 0;
    margin: 0;
  }

  @media (min-width: 1024px) {
    .desktop-nav {
      display: flex;
    }
  }

  .nav-list {
    display: flex;
    gap: 0;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    padding: var(--nav-item-padding);
    font-size: var(--nav-item-font-size);
    font-weight: 500;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    position: relative;
    white-space: nowrap;
    transition:
      color 0.3s ease,
      opacity 0.3s ease;
  }

  .nav-link:hover {
    color: var(--nav-hover-color);
  }
  .nav-link.active {
    color: var(--nav-active-color);
  }

  .underline-hover {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--nav-active-color);
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .nav-link:hover .underline-hover,
  .nav-link.active .underline-hover {
    opacity: 1;
    transform: scaleX(1);
  }

  .hamburger-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.4rem;
    width: 48px;
    height: 48px;
    padding: 0;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-left: auto;
    z-index: 10001;
  }

  .hamburger-btn:hover {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.2);
  }

  @media (min-width: 1024px) {
    .hamburger-btn {
      display: none;
    }
  }

  .line {
    width: 20px;
    height: 2px;
    background: rgba(255, 255, 255, 0.8);
    border-radius: 1px;
    transition: all 0.3s ease;
  }

  .hamburger-btn.active .line-1 {
    transform: translateY(8px) rotate(45deg);
  }
  .hamburger-btn.active .line-2 {
    opacity: 0;
  }
  .hamburger-btn.active .line-3 {
    transform: translateY(-8px) rotate(-45deg);
  }

  .mobile-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    z-index: 9998;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .mobile-backdrop.active {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 1023px) {
    .mobile-backdrop {
      display: block;
    }
  }

  .mobile-drawer {
    display: none;
    position: fixed;
    top: 0;
    right: 0;
    width: 75%;
    max-width: 320px;
    height: 100dvh;
    background: linear-gradient(
      165deg,
      rgba(8, 25, 55, 0.98) 0%,
      rgba(5, 15, 30, 0.99) 100%
    );
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border-left: 1px solid rgba(255, 255, 255, 0.12);
    z-index: 10000;
    visibility: hidden;
    opacity: 0;
    transform: translateX(100%);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0s linear 0.4s;
    box-shadow: -15px 0 50px rgba(0, 0, 0, 0.5);
  }

  .mobile-drawer.active {
    visibility: visible;
    opacity: 1;
    transform: translateX(0);
    transition:
      opacity 0.4s ease,
      transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
      visibility 0s linear 0s;
  }

  @media (max-width: 1023px) {
    .mobile-drawer {
      display: block;
    }
  }

  .mobile-nav-list {
    display: flex;
    flex-direction: column;
    padding: 6rem 1.5rem 2rem;
    gap: 0.5rem;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    padding: 1.1rem 1.5rem;
    font-size: 1.15rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    border-radius: 12px;
    transition: all 0.3s ease;
    border: 1px solid transparent;
    position: relative;
    overflow: hidden;
  }

  .mobile-nav-link:active {
    background: rgba(255, 255, 255, 0.05);
    color: var(--nav-hover-color);
  }

  .mobile-nav-link.active {
    background: rgba(100, 180, 255, 0.1);
    color: var(--nav-active-color);
    font-weight: 600;
    border-left: 4px solid var(--nav-active-color);
    border-radius: 0 12px 12px 0;
    padding-left: 1.25rem;
  }
</style>

<script>
  function initMobileNav() {
    const hamburgerBtn = document.getElementById("hamburger-btn");
    const mobileDrawer = document.getElementById("mobile-drawer");
    const mobileBackdrop = document.getElementById("mobile-backdrop");
    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    if (!hamburgerBtn || !mobileDrawer) return;

    let isOpen = false;

    function openDrawer() {
      isOpen = true;
      hamburgerBtn?.classList.add("active");
      mobileDrawer?.classList.add("active");
      mobileDrawer?.setAttribute("aria-hidden", "false");
      mobileBackdrop?.classList.add("active");
      document.body.style.overflow = "hidden";
    }

    function closeDrawer() {
      isOpen = false;
      hamburgerBtn?.classList.remove("active");
      mobileDrawer?.classList.remove("active");
      mobileDrawer?.setAttribute("aria-hidden", "true");
      mobileBackdrop?.classList.remove("active");
      document.body.style.overflow = "";
    }

    function toggleDrawer() {
      if (isOpen) closeDrawer();
      else openDrawer();
    }

    hamburgerBtn.addEventListener("click", toggleDrawer);
    mobileBackdrop?.addEventListener("click", closeDrawer);
    mobileNavLinks.forEach((link) => {
      link.addEventListener("click", closeDrawer);
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && isOpen) closeDrawer();
    });

    document.addEventListener("astro:before-swap", closeDrawer, { once: true });
  }

  document.addEventListener("DOMContentLoaded", initMobileNav);
  document.addEventListener("astro:after-swap", initMobileNav);
</script>
