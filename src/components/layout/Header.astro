---
/**
 * Header.astro
 * Navigasi utama Cloudsi Connect — glassmorphism navbar dengan horizontal menu
 */
const currentPath = Astro.url.pathname;
const navLinks = [
  { href: '/', label: 'Beranda' },
  { href: '/tentang', label: 'Tentang' },
  { href: '/galeri', label: 'Galeri' },
  { href: '/anggota', label: 'Anggota' },
  { href: '/acara', label: 'Acara' },
  { href: '/kontak', label: 'Kontak' },
  { href: '/lagu', label: 'Lagu Angkatan' },
];
---

<header class="header-nav" id="main-header">
  <div class="header-container">
    
    <!-- Logo Typography -->
    <a href="/" class="header-logo-group">
      <img src="/logo-angkatan-25.webp" alt="Logo Cloudsi" class="header-logo-img" />
      <div class="header-logo-text-group">
        <h1 class="header-logo-text">CLOUDSI</h1>
        <span class="header-logo-sub">Sistem Informasi UNTAN</span>
      </div>
    </a>

    <!-- Interactive Nav Wrapper -->
    <div class="interactive-nav-wrapper">
      
      <!-- Horizontal Navigation List (Toggled via Hamburger) -->
      <nav class="horizontal-nav" id="horizontal-menu" aria-label="Desktop menu">
        <ul class="nav-list">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class:list={['nav-link', { 'active': link.href === currentPath || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
              >
                {link.label}
                <span class="underline-hover"></span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Hamburger Toggle (All Screens) -->
      <button id="hamburger-btn" class="hamburger-btn glass-btn" aria-label="Toggle menu" aria-expanded="false">
        <span class="line line-1"></span>
        <span class="line line-2"></span>
        <span class="line line-3"></span>
      </button>

    </div>
  </div>
</header>

<style>
  /* Header Container Styling */
  .header-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background: var(--glass-bg);
    backdrop-filter: var(--blur-glass-heavy);
    -webkit-backdrop-filter: var(--blur-glass-heavy);
    border-bottom: 1px solid var(--glass-border);
    transition: box-shadow 0.3s ease;
  }

  .header-nav.scrolled {
    box-shadow: var(--shadow-glass);
  }

  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 60px; /* Mobile height */
    padding: 0 var(--gutter);
  }

  @media(min-width: 768px) {
    .header-container {
      height: 72px; /* Desktop height */
    }
  }

  /* Logo */
  .header-logo-group {
    display: flex;
    align-items: center;
    gap: 12px;
    color: inherit;
    text-decoration: none;
    z-index: 105;
  }

  .header-logo-img {
    height: 36px;
    width: auto;
    border-radius: 4px; /* Optional: adjust based on logo shape */
    object-fit: contain;
  }

  .header-logo-text-group {
    display: flex;
    flex-direction: column;
    justify-content: center;
    line-height: 1;
  }
  
  .header-logo-text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.2em;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    padding: 0;
  }

  @media(min-width: 768px) {
    .header-logo-text { font-size: 1.3rem; }
    .header-logo-img { height: 42px; }
  }

  .header-logo-sub {
    font-family: var(--font-body);
    font-size: 0.65rem;
    opacity: 0.6;
    margin-top: 4px;
    letter-spacing: 0.05em;
  }

  /* Navigation Wrapper */
  .interactive-nav-wrapper {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    /* Max width agar tidak menimpa logo di layar kecil, sisanya bisa di scroll kesamping */
    max-width: calc(100vw - 120px); 
    justify-content: flex-end;
  }

  /* Horizontal Navigation List */
  .horizontal-nav {
    display: flex;
    opacity: 0;
    pointer-events: none;
    transform: translateX(30px);
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    
    /* Wajib untuk HP layar kecil agar berjejer menyamping, BUKAN numpuk ke bawah */
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none; /* Firefox */
  }
  
  .horizontal-nav::-webkit-scrollbar {
    display: none; /* Chrome/Safari */
  }

  .horizontal-nav.open {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
  }

  .nav-list {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem; /* Jarak standar antar teks menu */
    flex-wrap: nowrap; /* CRUCIAL: Cegah teks numpuk jadi vertikal vertikal */
  }

  /* Nav Links Desktop Style */
  .nav-link {
    font-family: var(--font-display);
    font-size: 0.95rem; /* Menyamai fitur lama */
    font-weight: 500;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.5rem 0;
    display: block;
    white-space: nowrap;
    letter-spacing: 0.05em;
  }

  .nav-link:hover, .nav-link.active {
    color: white;
  }

  .nav-link.active {
    font-weight: 600;
  }

  .underline-hover {
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 2px;
    background: #38bdf8;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.86, 0, 0.07, 1);
    border-radius: 2px;
  }

  .nav-link:hover .underline-hover,
  .nav-link.active .underline-hover {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* === HAMBURGER BUTTON GLASSMORPHISM === */
  .hamburger-btn {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    cursor: pointer;
    width: 42px;
    height: 42px;
    padding: 0;
    position: relative;
    z-index: 102; 
    transition: all 0.3s ease;
    flex-shrink: 0;
  }

  /* Glow effect pada hover/touch khusus kotak ornamen */
  .hamburger-btn:hover, .hamburger-btn:focus-visible {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(56, 189, 248, 0.5);
    box-shadow: 0 0 15px rgba(56, 189, 248, 0.4), inset 0 0 10px rgba(56, 189, 248, 0.1);
    transform: scale(1.05);
  }

  .line {
    position: absolute;
    height: 2px;
    width: 20px;
    background: white;
    border-radius: 2px;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease, top 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .line-1 { top: 12px; }
  .line-2 { top: 19px; }
  .line-3 { top: 26px; }

  /* Hamburger Open State (X) */
  .hamburger-btn[aria-expanded="true"] {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);
  }

  .hamburger-btn[aria-expanded="true"] .line-1 {
    transform: rotate(45deg);
    top: 19px;
  }
  .hamburger-btn[aria-expanded="true"] .line-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  .hamburger-btn[aria-expanded="true"] .line-3 {
    transform: rotate(-45deg);
    top: 19px;
  }

  @media(max-width: 768px) {
    .nav-list {
      gap: 1.25rem;
      padding-right: 0.5rem; /* ruang sisa saat di ujung scroll */
    }
    .nav-link {
      font-size: 0.85rem;
    }
    .header-logo-text { font-size: 1rem; }
    .interactive-nav-wrapper { gap: 1rem; }
  }

  @media(max-width: 480px) {
    .header-logo-text-group { display: none; }
  }
</style>

<script is:inline>
  function setupHeader() {
    const header = document.getElementById('main-header');
    const hamburgerBtn = document.getElementById('hamburger-btn');
    const horizontalMenu = document.getElementById('horizontal-menu');
    
    if(!header || !hamburgerBtn || !horizontalMenu) return;

    // Persistensi Menu: membaca memori per sesi (agar menu tetap nampil pas ganti halaman)
    const isMenuPersistedOpen = sessionStorage.getItem('cloudsi_nav_open') === 'true';

    // Set state awal sesuai memory
    if (isMenuPersistedOpen) {
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      horizontalMenu.classList.add('open');
    }

    // Scroll Observer for shadow
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          if (window.scrollY > 20) {
            header.classList.add('scrolled');
          } else {
            header.classList.remove('scrolled');
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });

    // Initial check
    if (window.scrollY > 20) header.classList.add('scrolled');

    function toggleMenu() {
      const isExpanded = hamburgerBtn.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        horizontalMenu.classList.remove('open');
        sessionStorage.setItem('cloudsi_nav_open', 'false');
      } else {
        hamburgerBtn.setAttribute('aria-expanded', 'true');
        horizontalMenu.classList.add('open');
        sessionStorage.setItem('cloudsi_nav_open', 'true');
      }
    }

    // Hindari pendobelan event listener dengan Astro View Transitions
    hamburgerBtn.removeEventListener('click', toggleMenu);
    hamburgerBtn.addEventListener('click', toggleMenu);
  }

  document.addEventListener('DOMContentLoaded', setupHeader);
  document.addEventListener('astro:after-swap', setupHeader);
</script>
