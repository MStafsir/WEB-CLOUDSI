---
/**
 * WaterRipple.astro
 * WebGL water ripple effect menggunakan OGL (Ping-pong height map fluid simulation)
 * Posisi fixed, z-index: 0, pointer-events: none
 */
---

<canvas id="water-ripple-canvas" class="water-ripple-canvas" aria-hidden="true"></canvas>

<style>
  .water-ripple-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
  
  /* Fallback CSS Only */
  :global(.webgl-fallback) .water-ripple-canvas {
    pointer-events: auto; /* Untuk klik CSS ripples */
    background: linear-gradient(135deg, var(--color-sky-deep), var(--color-sky-mid), var(--color-sky-surface));
    background-size: 300% 300%;
    animation: skyGradient 15s ease infinite;
  }

  @keyframes skyGradient {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
</style>

<script is:inline>
  (async function() {
    async function initWaterRipple() {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      const canvas = document.getElementById('water-ripple-canvas');
      if (!canvas) return;

      // 1. Cek WebGL2 support
      const gl = canvas.getContext('webgl2', { alpha: true });
      if (!gl) {
        console.warn('[Cloudsi] WebGL2 tidak didukung. Fallback ke CSS mode.');
        document.body.classList.add('webgl-fallback');
        return;
      }

      // Battery API check
      try {
        if ('getBattery' in navigator) {
          const battery = await navigator.getBattery();
          if (battery.level < 0.2 && !battery.charging) {
             console.warn('[Cloudsi] Battery level low, disabling WebGL.');
             document.body.classList.add('webgl-fallback');
             return;
          }
        }
      } catch (e) { /* Ignored */ }

      try {
        const { Renderer, Program, Mesh, RenderTarget, Triangle } = await import('ogl');

        const renderer = new Renderer({
          canvas,
          gl,
          alpha: true,
          dpr: Math.min(window.devicePixelRatio, 2),
        });

        const simulationRes = 256;

        function createRT() {
          return new RenderTarget(gl, {
            width: simulationRes,
            height: simulationRes,
            type: gl.HALF_FLOAT || gl.FLOAT,
            internalFormat: gl.RGBA16F || gl.RGBA,
            format: gl.RGBA,
            depth: false,
          });
        }

        // 3 buffers: current, previous, output
        let rtCurrent = createRT();
        let rtPrevious = createRT();
        let rtOutput = createRT();

        const simVertex = /* glsl */ `
          attribute vec2 position;
          attribute vec2 uv;
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = vec4(position, 0.0, 1.0);
          }
        `;

        const simFragment = /* glsl */ `
          precision highp float;
          uniform sampler2D uCurrent;
          uniform sampler2D uPrevious;
          uniform vec2 uResolution;
          uniform vec2 uDropPos;
          uniform float uDropRadius;
          uniform float uDropStrength;
          uniform float uDamping;
          uniform bool uAddDrop;
          varying vec2 vUv;

          void main() {
            vec2 texel = 1.0 / uResolution;
            float current = texture2D(uCurrent, vUv).r;
            float previous = texture2D(uPrevious, vUv).r;
            float top = texture2D(uCurrent, vUv - vec2(0.0, texel.y)).r;
            float bottom = texture2D(uCurrent, vUv + vec2(0.0, texel.y)).r;
            float left = texture2D(uCurrent, vUv - vec2(texel.x, 0.0)).r;
            float right = texture2D(uCurrent, vUv + vec2(texel.x, 0.0)).r;
            float next = (top + bottom + left + right) * 0.5 - previous;
            next *= uDamping;

            if (uAddDrop) {
              float dist = distance(vUv, uDropPos);
              if (dist < uDropRadius) {
                float drop = exp(-dist * dist / (uDropRadius * uDropRadius * 0.1)) * uDropStrength;
                next -= drop;
              }
            }
            next = clamp(next, -1.0, 1.0);
            gl_FragColor = vec4(next, 0.0, 0.0, 1.0);
          }
        `;

        const triangle = new Triangle(gl);
        
        const simProgram = new Program(gl, {
          vertex: simVertex,
          fragment: simFragment,
          uniforms: {
            uCurrent: { value: null },
            uPrevious: { value: null },
            uResolution: { value: [simulationRes, simulationRes] },
            uDropPos: { value: [-1, -1] },
            uDropRadius: { value: 0.012 },
            uDropStrength: { value: 0.8 },
            uDamping: { value: 0.985 },
            uAddDrop: { value: false },
          },
        });
        const simMesh = new Mesh(gl, { geometry: triangle, program: simProgram });

        const renderFragment = /* glsl */ `
          precision highp float;
          uniform sampler2D tWaterMap;
          uniform vec2 uResolution;
          varying vec2 vUv;
          
          void main() {
            float height = texture2D(tWaterMap, vUv).r;
            vec2 texel = 1.0 / uResolution;
            float dx = texture2D(tWaterMap, vec2(vUv.x + texel.x, vUv.y)).r - texture2D(tWaterMap, vec2(vUv.x - texel.x, vUv.y)).r;
            float dy = texture2D(tWaterMap, vec2(vUv.x, vUv.y + texel.y)).r - texture2D(tWaterMap, vec2(vUv.x, vUv.y - texel.y)).r;
            vec3 normal = normalize(vec3(-dx * 100.0, -dy * 100.0, 1.0));

            vec3 skyDeep = vec3(0.024, 0.043, 0.067); 
            vec3 skyMid = vec3(0.063, 0.114, 0.176);  
            vec3 waterLight = vec3(0.196, 0.698, 0.835);
            vec3 bgColor = mix(skyDeep, skyMid, vUv.y);
            
            vec3 lightDir = normalize(vec3(1.0, 1.0, 1.0));
            float spec = pow(max(dot(normal, lightDir), 0.0), 32.0);
            vec3 color = mix(bgColor, waterLight, smoothstep(0.01, 0.5, height) * 0.4);
            color += spec * waterLight * 0.5;

            gl_FragColor = vec4(color, 1.0);
          }
        `;

        const renderProgram = new Program(gl, {
          vertex: simVertex,
          fragment: renderFragment,
          uniforms: {
            tWaterMap: { value: null },
            uResolution: { value: [window.innerWidth, window.innerHeight] },
          },
          transparent: false
        });
        const renderMesh = new Mesh(gl, { geometry: triangle, program: renderProgram });

        let dropQueue = [];
        let rAFId;
        let isDragging = false;

        function resize() {
          renderer.setSize(window.innerWidth, window.innerHeight);
          renderProgram.uniforms.uResolution.value = [window.innerWidth, window.innerHeight];
        }
        window.addEventListener('resize', resize);
        resize();

        function addDrop(x, y) {
          dropQueue.push({ x: x / window.innerWidth, y: 1.0 - (y / window.innerHeight) });
        }

        window.addEventListener('click', (e) => addDrop(e.clientX, e.clientY));
        window.addEventListener('pointerdown', (e) => { isDragging = true; addDrop(e.clientX, e.clientY); });
        window.addEventListener('pointerup', () => { isDragging = false; });
        
        let lastMove = 0;
        window.addEventListener('pointermove', (e) => {
          if (isDragging && performance.now() - lastMove > 50) {
            addDrop(e.clientX, e.clientY);
            lastMove = performance.now();
          }
        });

        // Animation Loop — proper ping-pong: read from current+previous, write to output, then rotate
        function animate(t) {
          rAFId = requestAnimationFrame(animate);

          // Set uniforms to READ from current and previous
          simProgram.uniforms.uCurrent.value = rtCurrent.texture;
          simProgram.uniforms.uPrevious.value = rtPrevious.texture;

          if (dropQueue.length > 0) {
            let drop = dropQueue.shift();
            simProgram.uniforms.uDropPos.value = [drop.x, drop.y];
            simProgram.uniforms.uAddDrop.value = true;
          } else {
            simProgram.uniforms.uAddDrop.value = false;
          }

          // WRITE to output (which is NOT being read)
          renderer.render({ scene: simMesh, target: rtOutput, clear: false });

          // Render the output to screen
          renderProgram.uniforms.tWaterMap.value = rtOutput.texture;
          renderer.render({ scene: renderMesh });

          // Rotate buffers: previous <- current, current <- output, output <- previous
          let tmp = rtPrevious;
          rtPrevious = rtCurrent;
          rtCurrent = rtOutput;
          rtOutput = tmp;
        }
        rAFId = requestAnimationFrame(animate);

        document.addEventListener('astro:before-swap', () => {
          cancelAnimationFrame(rAFId);
          window.removeEventListener('resize', resize);
          renderer.gl.getExtension('WEBGL_lose_context')?.loseContext();
        }, { once: true });

      } catch (err) {
        console.warn('[Cloudsi] WebGL Init Gagal, fallback ke CSS. Error:', err);
        document.body.classList.add('webgl-fallback');
      }
    }

    document.addEventListener('DOMContentLoaded', initWaterRipple);
    document.addEventListener('astro:after-swap', initWaterRipple);
  })();
</script>
