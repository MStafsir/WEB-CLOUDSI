---
/**
 * WaterRipple.astro
 * OGL-based Physical Water Surface (Spring Simulation)
 * Ultra-smooth, high-res raindrop ripples with pure video refraction (SIAKAD style).
 */
---

<canvas id="water-canvas" class="water-canvas" aria-hidden="true"></canvas>

<style>
  .water-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<script is:inline>
  (async function() {
    'use strict';

    function initWaterRipple() {
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (prefersReduced) return;

      const canvas = document.getElementById('water-canvas');
      if (!canvas) return;

      try {
        if ('getBattery' in navigator) {
          navigator.getBattery().then(battery => {
            if (battery.level < 0.2 && !battery.charging) {
               console.warn('[Cloudsi] Baterai rendah, mematikan efek air.');
               return; 
            }
          });
        }
      } catch (e) {}

      import('ogl').then(({ Renderer, Program, Mesh, RenderTarget, Triangle, Texture }) => {
        
        // === DETEKSI PERANGKAT ===
        const isMobile = window.innerWidth < 768 || ('ontouchstart' in window);
        const dprLimit = isMobile ? 1.5 : 2;

        const renderer = new Renderer({
          canvas,
          alpha: true,
          dpr: Math.min(window.devicePixelRatio, dprLimit),
        });
        const gl = renderer.gl;
        
        // Mobile: 256 (lancar), Desktop: 512 (super halus)
        const simulationRes = isMobile ? 256 : 512;

        function createRT() {
          return new RenderTarget(gl, {
            width: simulationRes,
            height: simulationRes,
            type: gl.HALF_FLOAT || gl.FLOAT,
            internalFormat: gl.RGBA16F || gl.RGBA,
            format: gl.RGBA,
            depth: false,
            minFilter: gl.LINEAR,
            magFilter: gl.LINEAR,
          });
        }

        let rtCurrent = createRT();
        let rtPrevious = createRT();
        let rtOutput = createRT();

        const videoEl = document.getElementById('bg-hero-video') || document.getElementById('cloud-canvas');
        let videoTex = null;
        if (videoEl) {
          // [FIX] Jangan load video secara buta kalau state-nya masih 0 (bisa bikin WebGL Crash)
          // Berikan gambar dummy 1x1 pixel lebih dulu
          videoTex = new Texture(gl, {
            image: new Uint8Array([0, 0, 0, 255]),
            width: 1, 
            height: 1,
            generateMipmaps: false,
            minFilter: gl.LINEAR,
            magFilter: gl.LINEAR,
            flipY: true, 
          });
        }

        const simVertex = /* glsl */ `
          attribute vec2 position;
          attribute vec2 uv;
          varying vec2 vUv;
          void main() {
            vUv = uv;
            gl_Position = vec4(position, 0.0, 1.0);
          }
        `;

        const simFragment = /* glsl */ `
          precision highp float;
          uniform sampler2D uCurrent;
          uniform sampler2D uPrevious;
          uniform vec2 uResolution;
          uniform vec2 uDropPos;
          uniform float uDropRadius;
          uniform float uDropStrength;
          uniform float uDamping;
          uniform bool uAddDrop;
          varying vec2 vUv;

          void main() {
            vec2 texel = 1.0 / uResolution;
            
            float current = texture2D(uCurrent, vUv).r;
            float previous = texture2D(uPrevious, vUv).r;
            
            float top = texture2D(uCurrent, vUv - vec2(0.0, texel.y)).r;
            float bottom = texture2D(uCurrent, vUv + vec2(0.0, texel.y)).r;
            float left = texture2D(uCurrent, vUv - vec2(texel.x, 0.0)).r;
            float right = texture2D(uCurrent, vUv + vec2(texel.x, 0.0)).r;
            
            float next = (top + bottom + left + right) * 0.5 - previous;
            next *= uDamping;

            if (uAddDrop) {
              float dist = distance(vUv, uDropPos);
              if (dist < uDropRadius) {
                float drop = exp(-dist * dist / (uDropRadius * uDropRadius * 0.1)) * uDropStrength;
                next -= drop;
              }
            }
            
            next = clamp(next, -1.0, 1.0);
            gl_FragColor = vec4(next, 0.0, 0.0, 1.0);
          }
        `;

        const triangle = new Triangle(gl);
        
        const simProgram = new Program(gl, {
          vertex: simVertex,
          fragment: simFragment,
          uniforms: {
            uCurrent: { value: null },
            uPrevious: { value: null },
            uResolution: { value: [simulationRes, simulationRes] },
            uDropPos: { value: [-1, -1] },
            uDropRadius: { value: 0.008 }, // [FIX] Diperkecil dari 0.02 agar riak tidak berlebihan dan pusing
            uDropStrength: { value: 0.4 }, // [FIX] Kurangi kekuatan hantaman agar elegan
            uDamping: { value: 0.95 },     // [FIX] Kurangi dari 0.985 agar gelombang cepat reda dan tenang
            uAddDrop: { value: false },
          },
        });
        
        const simMesh = new Mesh(gl, { geometry: triangle, program: simProgram });

        const renderFragment = /* glsl */ `
          precision highp float;
          uniform sampler2D tWaterMap;
          uniform sampler2D tVideoMap;
          uniform bool uHasVideo;
          uniform vec2 uResolution;
          uniform vec2 uVideoScale;
          varying vec2 vUv;
          
          void main() {
            // Kita gunakan vUv asli tanpa pembalikkan karena flipY:true sudah menangani pembalikkan!
            float height = texture2D(tWaterMap, vUv).r;
            vec2 texel = 1.0 / uResolution;
            
            float dx = texture2D(tWaterMap, vec2(vUv.x + texel.x, vUv.y)).r - texture2D(tWaterMap, vec2(vUv.x - texel.x, vUv.y)).r;
            float dy = texture2D(tWaterMap, vec2(vUv.x, vUv.y + texel.y)).r - texture2D(tWaterMap, vec2(vUv.x, vUv.y - texel.y)).r;
            vec3 normal = normalize(vec3(-dx * 40.0, -dy * 40.0, 1.0));

            // [FIX] Algoritma Skala Object-Cover Akurat untuk menyingkronkan ukuran video WebGL dengan HTML sepenuhnya
            vec2 videoUv = (vUv - 0.5) * uVideoScale + 0.5;

            // Distorsi/Refraksi UV: Pembayaran Lensa Air
            vec2 distortion = normal.xy * 0.1; 
            vec2 finalVideoUv = clamp(videoUv + distortion, 0.0, 1.0);
            
            vec3 bgColor;
            if (uHasVideo) {
               bgColor = texture2D(tVideoMap, finalVideoUv).rgb;
            } else {
               bgColor = vec3(0.024, 0.043, 0.067); 
            }

            // Tint Overlay agar menyatu dengan gelapnya website
            vec3 overlayColor = vec3(0.011, 0.057, 0.103);
            bgColor = mix(bgColor, overlayColor, 0.55);

            vec3 lightDir = normalize(vec3(0.5, 0.8, 1.0));
            float spec = pow(max(dot(normal, lightDir), 0.0), 40.0);
            
            vec3 finalColor = bgColor + (vec3(1.0) * spec * 0.25); 

            gl_FragColor = vec4(finalColor, 1.0);
          }
        `;

        const renderProgram = new Program(gl, {
          vertex: simVertex,
          fragment: renderFragment,
          uniforms: {
            tWaterMap: { value: null },
            tVideoMap: { value: videoTex },
            uHasVideo: { value: videoEl != null },
            uResolution: { value: [window.innerWidth, window.innerHeight] },
            uVideoScale: { value: [1, 1] }, // Akan dikalkulasi di animate loop
          },
          transparent: false
        });
        const renderMesh = new Mesh(gl, { geometry: triangle, program: renderProgram });

        let dropQueue = [];
        let rAFId;

        // [FIX] Pergerakan Y sudah benar secara otomatis karena kita menghilangkan balikan paksa shader. 
        // Titik kursor langsung menyentuh titik sebenarnya!
        function addDrop(x, y) {
           dropQueue.push({ x: x / window.innerWidth, y: 1.0 - (y / window.innerHeight) });
        }

        window.addEventListener('resize', () => {
          renderer.setSize(window.innerWidth, window.innerHeight);
          renderProgram.uniforms.uResolution.value = [window.innerWidth, window.innerHeight];
        });
        renderer.setSize(window.innerWidth, window.innerHeight);

        let lastMove = 0;
        const moveThrottle = isMobile ? 40 : 20; // Mobile: lebih jarang agar tak kelebihan beban
        const handleDragMove = (e) => {
          if (performance.now() - lastMove > moveThrottle) {
             const cx = e.touches ? e.touches[0].clientX : e.clientX;
             const cy = e.touches ? e.touches[0].clientY : e.clientY;
             addDrop(cx, cy);
             lastMove = performance.now();
          }
        };

        window.addEventListener('mousemove', handleDragMove);
        window.addEventListener('touchmove', handleDragMove, {passive: true});
        
        function animate(t) {
          rAFId = requestAnimationFrame(animate);

          // Cek kesiapan sumber background
          if (videoTex && videoEl) {
             const isVideo = videoEl.tagName.toLowerCase() === 'video';
             const isReady = isVideo ? videoEl.readyState >= 2 : true;

             if (isReady) {
               // Update texture ke elemen sumber jika masih array
               if (videoTex.image instanceof Uint8Array || !isVideo) {
                 videoTex.image = videoEl;
               }
               // Canvas perlu diupdate terus menerus, video juga!
               videoTex.needsUpdate = true;
               
               // Kalkulasi Object-Cover Matematika Akurat
               const cW = window.innerWidth;
               const cH = window.innerHeight;
               const vW = isVideo ? (videoEl.videoWidth || 1920) : (videoEl.width || window.innerWidth);
               const vH = isVideo ? (videoEl.videoHeight || 1080) : (videoEl.height || window.innerHeight);
               const scale = Math.max(cW / vW, cH / vH);
               const rW = vW * scale;
               const rH = vH * scale;
               renderProgram.uniforms.uVideoScale.value = [cW / rW, cH / rH];
             }
          }

          simProgram.uniforms.uCurrent.value = rtCurrent.texture;
          simProgram.uniforms.uPrevious.value = rtPrevious.texture;

          if (dropQueue.length > 0) {
            let drop = dropQueue.shift();
            simProgram.uniforms.uDropPos.value = [drop.x, drop.y];
            simProgram.uniforms.uAddDrop.value = true;
          } else {
            simProgram.uniforms.uAddDrop.value = false;
          }

          renderer.render({ scene: simMesh, target: rtOutput, clear: false });

          renderProgram.uniforms.tWaterMap.value = rtOutput.texture;
          renderer.render({ scene: renderMesh });

          let tmp = rtPrevious;
          rtPrevious = rtCurrent;
          rtCurrent = rtOutput;
          rtOutput = tmp;
        }

        setTimeout(() => addDrop(window.innerWidth/2, window.innerHeight/2), 500);

        rAFId = requestAnimationFrame(animate);

        document.addEventListener('astro:before-swap', () => {
          cancelAnimationFrame(rAFId);
          gl.getExtension('WEBGL_lose_context')?.loseContext();
        }, { once: true });
        
      }).catch(err => {
        console.warn('Gagal muat modul OGL:', err);
      });
    }

        function scheduleWater() {
          if ('requestIdleCallback' in window) {
            requestIdleCallback(initWaterRipple, { timeout: 1000 });
          } else {
            setTimeout(initWaterRipple, 300);
          }
        }
    document.addEventListener('DOMContentLoaded', scheduleWater);
    document.addEventListener('astro:after-swap', scheduleWater);
  })();
</script>
