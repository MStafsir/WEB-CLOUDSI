---
/**
 * Button.astro
 * Komponen tombol reusable — glass style dengan variants
 * Props: variant, size, href (opsional untuk link-button), type
 * Dependencies: global.css (tokens)
 */

interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  id?: string;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className = '',
  id,
} = Astro.props;

const Tag = href ? 'a' : 'button';
const tagProps = href
  ? { href }
  : { type };
---

<Tag
  class:list={[
    'btn',
    `btn--${variant}`,
    `btn--${size}`,
    className,
  ]}
  id={id}
  {...tagProps}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-family: var(--font-body);
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: 12px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--duration-normal) var(--ease-glass);
    position: relative;
    overflow: hidden;
  }

  /* Sizes */
  .btn--sm {
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
  }

  .btn--md {
    padding: 0.75rem 1.75rem;
    font-size: 0.875rem;
  }

  .btn--lg {
    padding: 1rem 2.5rem;
    font-size: 1rem;
  }

  /* Primary — water gradient */
  .btn--primary {
    background: linear-gradient(
      135deg,
      var(--color-water-surface) 0%,
      var(--color-water-light) 100%
    );
    color: var(--color-sky-deep);
    border-color: var(--color-water-light);
    box-shadow: 0 4px 20px hsla(190, 65%, 55%, 0.25);
  }

  .btn--primary:hover {
    box-shadow: 0 8px 32px hsla(190, 65%, 55%, 0.4);
    transform: translateY(-2px);
  }

  .btn--primary:active {
    transform: translateY(0);
  }

  /* Secondary — glass */
  .btn--secondary {
    background: var(--glass-bg);
    backdrop-filter: var(--blur-glass);
    -webkit-backdrop-filter: var(--blur-glass);
    color: var(--color-water-light);
    border-color: var(--glass-border);
    box-shadow: var(--shadow-glass);
  }

  .btn--secondary:hover {
    background: var(--glass-bg-hover);
    border-color: var(--glass-border-hover);
    box-shadow: var(--shadow-glass-hover);
    transform: translateY(-2px);
  }

  /* Ghost — transparent */
  .btn--ghost {
    background: transparent;
    color: var(--color-water-light);
    border-color: var(--glass-border);
  }

  .btn--ghost:hover {
    background: var(--glass-bg);
    border-color: var(--glass-border-hover);
  }

  /* Ripple on click */
  .btn::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, hsla(0, 0%, 100%, 0.2) 0%, transparent 70%);
    opacity: 0;
    transform: scale(0);
    transition: opacity var(--duration-fast), transform var(--duration-normal) var(--ease-water);
  }

  .btn:active::after {
    opacity: 1;
    transform: scale(2.5);
    transition: opacity 0ms, transform 0ms;
  }
</style>
