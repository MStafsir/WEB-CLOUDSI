---
import type { Member } from '../../types/index';

interface Props {
  member: Member;
}

const { member } = Astro.props;

// Algoritma Fallback inisial dan hue
function getInitials(name: string): string {
  if (!name) return '??';
  return name.split(' ').slice(0, 2).map(n => n[0]).join('').toUpperCase();
}

function nameToHue(name: string): number {
  if (!name) return 0;
  return name.split('').reduce((acc, c) => acc + c.charCodeAt(0), 0) % 360;
}

const initials = getInitials(member.full_name);
const hue = nameToHue(member.full_name);

// Foto selalu lokal /members/xxx.jpg
const photoSrc = member.photo_url;
---
<article class="member-card" data-member-card style={`--card-hue: ${hue};`}>
  <!-- Animated gradient border -->
  <div class="card-glow-border"></div>
  
  <div class="member-card-inner">
    <!-- Gambar/Fallback -->
    <div 
      class="member-photo-container" 
      style={`--fallback-hue: ${hue}; view-transition-name: member-${member.id};`}
    >
      <div class="member-fallback">
        <span>{initials}</span>
      </div>
      <img
        src={photoSrc}
        alt={`Foto ${member.full_name}`}
        loading="lazy"
        decoding="async"
        class="member-photo"
      />
      <!-- Gradient overlay bottom -->
      <div class="photo-gradient-overlay"></div>
    </div>

    <!-- Role Badge -->
    <div class="role-badge">
      {member.role}
    </div>

    <!-- Teks Depan (Selalu Tampil) -->
    <div class="member-front-info">
      <h3 class="member-front-name">{member.full_name}</h3>
    </div>

    <!-- Hover Panel (Slide Up CSS) -->
    <div class="member-hover-panel">
      <div class="panel-content">
        <h4 class="panel-name">{member.full_name}</h4>
        {member.nickname && <span class="panel-nickname">({member.nickname})</span>}
        
        {member.quote && <p class="panel-quote">"{member.quote}"</p>}

        <div class="panel-socials">
          {member.social_ig && (
            <a href={`https://instagram.com/${member.social_ig}`} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={`Instagram ${member.full_name}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
          )}
          {member.social_in && (
            <a href={`https://linkedin.com/in/${member.social_in}`} target="_blank" rel="noopener noreferrer" class="social-icon-btn" aria-label={`LinkedIn ${member.full_name}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect x="2" y="9" width="4" height="12"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
            </a>
          )}
        </div>
      </div>
    </div>
  </div>
</article>

<style>
  /* === CARD WITH ANIMATED GRADIENT BORDER === */
  .member-card {
    position: relative;
    width: 100%;
    aspect-ratio: 2/3;
    border-radius: 14px;
    cursor: pointer;
    padding: 2px;
  }

  /* Animated border glow */
  .card-glow-border {
    position: absolute;
    inset: 0;
    border-radius: 14px;
    background: conic-gradient(
      from 0deg,
      hsla(var(--card-hue), 70%, 55%, 0),
      hsla(var(--card-hue), 70%, 55%, 0.4),
      hsla(calc(var(--card-hue) + 60), 70%, 55%, 0.2),
      hsla(var(--card-hue), 70%, 55%, 0)
    );
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: 0;
  }

  @media (hover: hover) {
    .member-card:hover .card-glow-border {
      opacity: 1;
      animation: borderRotate 4s linear infinite;
    }
    .member-card:hover .member-hover-panel {
      transform: translateY(0);
    }
    .member-card:hover .member-photo {
      transform: scale(1.08);
    }
    .member-card:hover .member-card-inner {
      border-color: hsla(var(--card-hue), 55%, 50%, 0.35);
      box-shadow: 
        0 0 25px hsla(var(--card-hue), 60%, 45%, 0.12),
        0 4px 20px hsla(210, 60%, 4%, 0.4);
    }
    .member-card:hover .role-badge {
      background: hsla(var(--card-hue), 50%, 40%, 0.35);
      border-color: hsla(var(--card-hue), 55%, 50%, 0.35);
    }
  }

  @keyframes borderRotate {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
  }

  .member-card.is-active .card-glow-border {
    opacity: 1;
    animation: borderRotate 4s linear infinite;
  }

  .member-card.is-active .member-hover-panel {
    transform: translateY(0);
  }

  .member-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--glass-border);
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
    z-index: 1;
  }

  .member-photo-container {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background: hsl(var(--fallback-hue), 40%, 15%);
  }

  .member-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 2.5rem;
    color: hsla(0, 0%, 100%, 0.3);
    user-select: none;
    background: linear-gradient(135deg, 
      hsla(var(--fallback-hue), 40%, 18%, 1), 
      hsla(var(--fallback-hue), 30%, 12%, 1)
    );
  }

  .member-photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-water);
  }

  .photo-gradient-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, hsla(210, 60%, 6%, 0.95) 0%, hsla(210, 60%, 6%, 0.2) 35%, transparent 60%);
    pointer-events: none;
  }

  .role-badge {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    background: hsla(200, 50%, 20%, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid hsla(200, 80%, 70%, 0.15);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.55rem;
    font-weight: 600;
    color: hsla(0, 0%, 100%, 0.9);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    z-index: 2;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .member-front-info {
    position: absolute;
    bottom: 0.6rem;
    left: 0.75rem;
    right: 0.75rem;
    z-index: 2;
  }

  .member-front-name {
    font-family: var(--font-display);
    color: white;
    font-size: 0.9rem;
    font-weight: 400;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 0 2px 8px hsla(210, 60%, 4%, 0.6);
  }

  /* Hover Panel */
  .member-hover-panel {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 48%;
    background: hsla(210, 50%, 8%, 0.75);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid hsla(var(--card-hue), 50%, 50%, 0.15);
    transform: translateY(100%);
    transition: transform var(--duration-normal) var(--ease-glass);
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0.85rem;
  }

  .panel-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .panel-name {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 0.85rem;
    color: white;
    line-height: 1.2;
    margin: 0;
  }

  .panel-nickname {
    font-family: var(--font-body);
    font-style: italic;
    opacity: 0.6;
    font-size: 0.7rem;
    color: white;
  }

  .panel-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.75rem;
    color: hsla(0, 0%, 100%, 0.85);
    margin-top: 0.35rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.3;
  }

  .panel-socials {
    display: flex;
    gap: 0.4rem;
    margin-top: 0.5rem;
  }

  .social-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    color: white;
    text-decoration: none;
    border: 1px solid hsla(200, 80%, 70%, 0.15);
    background: hsla(200, 50%, 20%, 0.3);
    transition: all 0.25s ease;
  }

  .social-icon-btn:hover {
    transform: translateY(-2px);
    background: hsla(var(--card-hue), 50%, 40%, 0.4);
    border-color: hsla(var(--card-hue), 55%, 50%, 0.4);
    box-shadow: 0 2px 12px hsla(var(--card-hue), 50%, 50%, 0.2);
  }
</style>
