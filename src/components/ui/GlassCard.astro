---
/**
 * GlassCard.astro
 * Komponen kartu glassmorphism reusable
 * Props: tag (HTML element), padding, hover (enable hover effect)
 * Dependencies: global.css (.glass utility)
 */

interface Props {
  tag?: 'div' | 'article' | 'section' | 'aside';
  padding?: 'sm' | 'md' | 'lg';
  hover?: boolean;
  class?: string;
}

const {
  tag: Tag = 'div',
  padding = 'md',
  hover = true,
  class: className = '',
} = Astro.props;

const paddingMap = {
  sm: '1rem',
  md: '1.5rem',
  lg: '2.5rem',
};
---

<Tag
  class:list={['glass-card glass', { 'glass-card--no-hover': !hover }, className]}
  style={`padding: ${paddingMap[padding]};`}
>
  <slot />
</Tag>

<style>
  .glass-card {
    position: relative;
    overflow: hidden;
  }

  .glass-card--no-hover:hover {
    background: var(--glass-bg);
    border-color: var(--glass-border);
    box-shadow: var(--shadow-glass);
  }

  /* Shimmer overlay on hover */
  .glass-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      hsla(200, 80%, 90%, 0.04),
      transparent
    );
    transition: left var(--duration-slow) var(--ease-water);
    pointer-events: none;
  }

  .glass-card:hover::before {
    left: 100%;
  }

  .glass-card--no-hover::before {
    display: none;
  }
</style>
